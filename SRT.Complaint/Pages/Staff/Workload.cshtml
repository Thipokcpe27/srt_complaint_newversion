@page
@model SRT.Complaint.Pages.Staff.WorkloadModel
@{
    ViewData["Title"] = "Workload ทีม";
}

<!-- ══ Summary Cards ══ -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">เจ้าหน้าที่ทั้งหมด</p>
        <p class="text-3xl font-bold text-srt-navy mt-1">@Model.TotalStaff</p>
        <p class="text-xs text-gray-400 mt-1">GeneralOfficer ที่ active</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">เรื่องที่เปิดอยู่รวม</p>
        <p class="text-3xl font-bold text-blue-600 mt-1">@Model.TotalOpenCases</p>
        <p class="text-xs text-gray-400 mt-1">Pending + InProgress</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">เฉลี่ยต่อคน</p>
        <p class="text-3xl font-bold text-amber-600 mt-1">@Model.AvgCasesPerStaff</p>
        <p class="text-xs text-gray-400 mt-1">เรื่อง / เจ้าหน้าที่ 1 คน</p>
    </div>
</div>

<!-- ══ Workload Table ══ -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <h2 class="text-sm font-semibold text-gray-900">Workload ของเจ้าหน้าที่แต่ละคน</h2>
        <span class="text-xs text-gray-400">เรียงจากมากไปน้อย</span>
    </div>

    @if (!Model.TeamWorkload.Any())
    {
        <div class="px-5 py-12 text-center">
            <svg class="w-12 h-12 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0" />
            </svg>
            <p class="text-sm text-gray-400">ยังไม่มีเจ้าหน้าที่ในระบบ</p>
        </div>
    }
    else
    {
        <div class="divide-y divide-gray-100">
            @foreach (var officer in Model.TeamWorkload)
            {
                var loadColor = officer.LoadPercent >= 80 ? "bg-red-500"
                              : officer.LoadPercent >= 50 ? "bg-amber-400"
                              : "bg-srt-navy";
                var textColor = officer.LoadPercent >= 80 ? "text-red-600"
                              : officer.LoadPercent >= 50 ? "text-amber-600"
                              : "text-gray-700";

                <div class="flex items-center gap-4 px-5 py-4">
                    <!-- Avatar -->
                    <div class="w-10 h-10 rounded-full bg-srt-navy/10 flex items-center justify-center
                                text-sm font-semibold text-srt-navy shrink-0">
                        @officer.Initials
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between mb-1.5">
                            <p class="text-sm font-medium text-gray-900 truncate">@officer.FullName</p>
                            <span class="text-sm font-semibold @textColor ml-4 shrink-0">
                                @officer.OpenCases เรื่อง
                            </span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-2">
                            <div class="@loadColor h-2 rounded-full transition-all duration-500"
                                 style="width: @(Math.Min(officer.LoadPercent, 100))%"
                                 role="progressbar"
                                 aria-valuenow="@officer.LoadPercent"
                                 aria-valuemin="0"
                                 aria-valuemax="100"></div>
                        </div>
                    </div>

                    <!-- Filter link -->
                    <a asp-page="/Staff/Queue"
                       asp-route-assignedToId="@officer.StaffId"
                       asp-route-status="InProgress"
                       class="text-xs text-srt-navy hover:underline font-medium shrink-0">
                        ดูเรื่อง →
                    </a>
                </div>
            }
        </div>
    }
</div>
