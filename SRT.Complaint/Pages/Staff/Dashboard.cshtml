@page
@model SRT.Complaint.Pages.Staff.DashboardModel
@{
    ViewData["Title"] = "แดชบอร์ด";
    var stats = Model.Stats;
    var todayChange = stats.YesterdayCount == 0
        ? (stats.TodayCount > 0 ? 100 : 0)
        : (int)Math.Round((double)(stats.TodayCount - stats.YesterdayCount) / stats.YesterdayCount * 100);
    var changeSign = todayChange >= 0 ? "+" : "";
    var changeColor = todayChange >= 0 ? "text-emerald-600" : "text-red-500";
    var changeArrow = todayChange >= 0 ? "↑" : "↓";
}

<!-- Page header -->
<div class="page-header">
    <div>
        <h1 class="page-title">แดชบอร์ด</h1>
        <p class="page-subtitle">ภาพรวมเรื่องร้องเรียน — อัปเดตทุกครั้งที่โหลด</p>
    </div>
    <a asp-page="/Staff/Queue" class="btn-primary btn-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        คิวเรื่อง
    </a>
</div>

<!-- ══ Stat Cards ══ -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

    <div class="stat-card">
        <div class="flex items-center justify-between">
            <p class="stat-label">รับวันนี้</p>
            <div class="stat-card-icon bg-srt-navy-50">
                <svg class="w-5 h-5 text-srt-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
        </div>
        <p class="stat-value text-srt-navy">@stats.TodayCount</p>
        <p class="stat-meta">
            <span class="@changeColor font-semibold">@changeArrow @changeSign@todayChange%</span>
            <span class="ml-1">จากเมื่อวาน</span>
        </p>
    </div>

    <div class="stat-card">
        <div class="flex items-center justify-between">
            <p class="stat-label">กำลังดำเนินการ</p>
            <div class="stat-card-icon bg-blue-50">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </div>
        </div>
        <p class="stat-value text-blue-600">@stats.InProgressCount</p>
        <p class="stat-meta">
            รับแล้ว <strong class="text-gray-700">@stats.AssignedCount</strong> ·
            <span class="text-amber-600 font-semibold">รอรับ @stats.UnassignedCount</span>
        </p>
    </div>

    <div class="stat-card border-amber-100">
        <div class="flex items-center justify-between">
            <p class="stat-label text-amber-600">ใกล้ครบ SLA</p>
            <div class="stat-card-icon bg-amber-50">
                <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
        <p class="stat-value text-amber-600">@stats.SlaWarningCount</p>
        <p class="stat-meta text-amber-500">เหลือน้อยกว่า 24 ชั่วโมง</p>
    </div>

    <div class="stat-card @(stats.SlaBreachedCount > 0 ? "border-red-200 bg-red-50" : "")">
        <div class="flex items-center justify-between">
            <p class="stat-label @(stats.SlaBreachedCount > 0 ? "text-red-600" : "")">เกิน SLA</p>
            <div class="stat-card-icon @(stats.SlaBreachedCount > 0 ? "bg-red-100" : "bg-gray-100")">
                <svg class="w-5 h-5 @(stats.SlaBreachedCount > 0 ? "text-red-600" : "text-gray-500")"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
        </div>
        <p class="stat-value text-red-600">@stats.SlaBreachedCount</p>
        @if (stats.SlaBreachedCount > 0)
        {
            <p class="stat-meta text-red-500 font-semibold">ต้องดำเนินการด่วน</p>
        }
        else
        {
            <p class="stat-meta text-emerald-500">สถานะปกติ</p>
        }
    </div>

</div>

<!-- ══ Chart + Category + SLA Warning ══ -->
<div class="grid grid-cols-1 lg:grid-cols-4 gap-5 mb-5">

    <!-- Bar Chart -->
    <div class="lg:col-span-2 card p-5">
        <div class="flex items-center justify-between mb-5">
            <div>
                <h2 class="text-sm font-bold text-gray-900">จำนวนเรื่องร้องเรียน 7 วันล่าสุด</h2>
                <p class="text-xs text-gray-400 mt-0.5">อัปเดตทุกครั้งที่โหลดหน้า</p>
            </div>
            <span class="badge-pending text-xs">7 วัน</span>
        </div>
        <canvas id="weeklyChart" height="85"></canvas>
    </div>

    <!-- Category Breakdown -->
    @{
        var maxTotal = stats.CategoryBreakdown.Any() ? stats.CategoryBreakdown.Max(x => x.Total) : 1;
    }
    <div class="card p-5">
        <h2 class="text-sm font-bold text-gray-900 mb-3">แยกตามประเภท</h2>
        @if (stats.CategoryBreakdown.Any())
        {
            <div class="space-y-2.5">
                @foreach (var item in stats.CategoryBreakdown)
                {
                    var pct = maxTotal > 0 ? (double)item.Total / maxTotal * 100 : 0;
                    var pctActive = item.Total > 0 ? (double)item.Active / item.Total * 100 : 0;
                    <div>
                        <div class="flex justify-between text-xs mb-1">
                            <span class="text-gray-600 truncate max-w-[75%]">@item.CategoryName</span>
                            <span class="font-semibold text-gray-800 shrink-0">@item.Total</span>
                        </div>
                        <div class="w-full h-1.5 rounded-full overflow-hidden" style="background:#EEF2FF;">
                            <div class="h-1.5 rounded-full relative overflow-hidden" style="width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%; background:#C7D2FE;">
                                <div class="absolute inset-y-0 left-0 rounded-full" style="width:@pctActive.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%; background:#0D2E6E;"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <p class="text-[10px] text-gray-400 mt-3">สีเข้ม = กำลังดำเนินการ</p>
        }
        else
        {
            <p class="text-xs text-gray-400">ยังไม่มีข้อมูล</p>
        }
    </div>

    <!-- SLA Warning List -->
    <div class="card p-5 border-amber-100">
        <h2 class="text-sm font-bold text-gray-900 mb-4 flex items-center gap-2">
            <div class="w-5 h-5 bg-amber-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-amber-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                </svg>
            </div>
            เรื่องใกล้ครบ / เกิน SLA
        </h2>

        @if (!stats.SlaWarningItems.Any())
        {
            <div class="empty-state py-8">
                <div class="empty-state-icon bg-emerald-50 mb-3">
                    <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <p class="text-sm font-medium text-gray-500">SLA ปกติทุกเรื่อง</p>
                <p class="text-xs text-gray-400 mt-1">ไม่มีเรื่องที่ใกล้เกิน SLA</p>
            </div>
        }
        else
        {
            <div class="space-y-2 max-h-60 overflow-y-auto pr-1">
                @foreach (var item in stats.SlaWarningItems)
                {
                    <a asp-page="/Staff/CaseDetail" asp-route-id="@item.Id"
                       class="flex items-center gap-3 p-3 rounded-xl border transition-all duration-150
                              @(item.SlaBreached ? "bg-red-50 border-red-200 hover:border-red-300" : "bg-amber-50 border-amber-100 hover:border-amber-200")">
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-bold text-gray-900 font-mono">@item.ReferenceNumber</p>
                            <p class="text-xs text-gray-500 truncate mt-0.5">@item.CategoryName</p>
                        </div>
                        <div class="text-right shrink-0">
                            <p class="text-xs font-bold @(item.SlaBreached ? "text-red-600" : "text-amber-600")">
                                @item.SlaRemainingText
                            </p>
                            <p class="text-[10px] text-gray-400 mt-0.5">@item.ReporterName</p>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

</div>

<!-- ══ Quick link to Workload ══ -->
<div class="card p-5 flex items-center justify-between">
    <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-srt-navy-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-srt-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0" />
            </svg>
        </div>
        <div>
            <h2 class="text-sm font-bold text-gray-900">Workload ทีมเจ้าหน้าที่</h2>
            <p class="text-xs text-gray-400 mt-0.5">ดูภาระงานและสถิติของแต่ละคน</p>
        </div>
    </div>
    <a asp-page="/Staff/Workload" class="btn-secondary btn-sm">
        ดูทั้งหมด
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
    </a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script>
    (function () {
        const ctx = document.getElementById('weeklyChart');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.ChartLabels)),
                datasets: [{
                    label: 'จำนวนเรื่อง',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.ChartData)),
                    backgroundColor: (ctx2) => {
                        const gradient = ctx2.chart.ctx.createLinearGradient(0, 0, 0, 200);
                        gradient.addColorStop(0, 'rgba(13,46,110,0.85)');
                        gradient.addColorStop(1, 'rgba(13,46,110,0.25)');
                        return gradient;
                    },
                    borderRadius: 8,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false },
                    tooltip: { callbacks: { label: ctx => ` ${ctx.parsed.y} เรื่อง` } }
                },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 },
                         grid: { color: 'rgba(0,0,0,0.05)' },
                         border: { display: false } },
                    x: { grid: { display: false }, border: { display: false } }
                }
            }
        });
        setTimeout(() => location.reload(), 60000);
    })();
    </script>
}
