@page "{id:int}"
@model SRT.Complaint.Pages.Staff.CaseDetailModel
@using System.Security.Claims
@{
    ViewData["Title"] = $"เรื่อง {Model.Complaint.ReferenceNumber}";
    var c = Model.Complaint;
    var currentStaffId = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
    var isAssignedToMe = c.AssignedToId == currentStaffId;
    var isClosed = c.Status is "Closed" or "Rejected";
    var now = DateTime.UtcNow;
    var slaBreached = c.SlaBreached || (c.SlaDeadline.HasValue && c.SlaDeadline < now);

    string StatusColor(string s) => s switch
    {
        "Pending"    => "bg-amber-100 text-amber-800 border-amber-200",
        "InProgress" => "bg-blue-100 text-blue-800 border-blue-200",
        "Resolved"   => "bg-green-100 text-green-800 border-green-200",
        "Closed"     => "bg-gray-200 text-gray-700 border-gray-300",
        "Rejected"   => "bg-red-100 text-red-800 border-red-200",
        _            => "bg-gray-100 text-gray-700 border-gray-200"
    };
    string PriorityColor(string p) => p switch
    {
        "Critical" => "bg-red-100 text-red-800 border-red-200",
        "Urgent"   => "bg-orange-100 text-orange-800 border-orange-200",
        "High"     => "bg-yellow-100 text-yellow-800 border-yellow-200",
        _          => "bg-gray-100 text-gray-700 border-gray-200"
    };
}

<!-- ══ Page Header ══ -->
<div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-3">
        <a asp-page="/Staff/Queue" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h1 class="text-base font-semibold text-gray-900 font-mono">@c.ReferenceNumber</h1>
        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border @StatusColor(c.Status)">
            @CaseDetailModel.StatusLabel(c.Status)
        </span>
        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border @PriorityColor(c.Priority)">
            @CaseDetailModel.PriorityLabel(c.Priority)
        </span>
        @if (slaBreached)
        {
            <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-600 text-white">⚠ เกิน SLA</span>
        }
    </div>
    <div class="flex items-center gap-3">
        <span class="text-xs text-gray-400">
            รับเมื่อ @c.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        </span>
        <button type="button" onclick="document.getElementById('pdf-modal').classList.remove('hidden')"
                class="inline-flex items-center gap-1.5 text-xs text-srt-navy border border-srt-navy/30
                       px-3 py-1.5 rounded-lg hover:bg-srt-navy hover:text-white transition">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            PDF
        </button>

        <!-- Modal เลือกรูปแบบ PDF -->
        <div id="pdf-modal"
             class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm"
             onclick="if(event.target===this)this.classList.add('hidden')">
            <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 p-6">
                <h3 class="text-base font-semibold text-gray-900 mb-1">ดาวน์โหลด PDF</h3>
                <p class="text-sm text-gray-500 mb-5">เลือกรูปแบบเอกสารที่ต้องการ</p>

                <!-- ตัวเลือก 1: ปกปิดชื่อ -->
                <form method="post" asp-page-handler="DownloadPdf" asp-route-id="@c.Id" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="maskReporter" value="true" />
                    <button type="submit"
                            class="w-full flex items-start gap-3 p-4 rounded-xl border-2 border-gray-200
                                   hover:border-blue-400 hover:bg-blue-50 active:bg-blue-100
                                   focus:outline-none transition text-left group">
                        <div class="mt-0.5 w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0
                                    group-hover:bg-blue-100 transition">
                            <svg class="w-4 h-4 text-gray-500 group-hover:text-blue-600 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-800">ปกปิดข้อมูลผู้ร้องเรียน</p>
                            <p class="text-xs text-gray-500 mt-0.5">สำหรับส่งต่อหน่วยงาน — แสดงข้อความ PDPA แทนชื่อ/เบอร์โทร</p>
                        </div>
                    </button>
                </form>

                <!-- ตัวเลือก 2: แสดงครบ -->
                <form method="post" asp-page-handler="DownloadPdf" asp-route-id="@c.Id">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="maskReporter" value="false" />
                    <button type="submit"
                            class="w-full flex items-start gap-3 p-4 rounded-xl border-2 border-gray-200
                                   hover:border-gray-400 hover:bg-gray-50 active:bg-gray-100
                                   focus:outline-none transition text-left group">
                        <div class="mt-0.5 w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0
                                    group-hover:bg-gray-200 transition">
                            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-gray-800">แสดงข้อมูลครบถ้วน</p>
                            <p class="text-xs text-gray-500 mt-0.5">สำหรับใช้ภายใน — แสดงชื่อ เบอร์โทร และอีเมลผู้ร้องเรียน</p>
                        </div>
                    </button>
                </form>

                <button type="button" onclick="document.getElementById('pdf-modal').classList.add('hidden')"
                        class="mt-4 w-full text-sm text-gray-400 hover:text-gray-600 transition">
                    ยกเลิก
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ══ Two-column layout ══ -->
<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ── Left: Complaint details + timeline ── -->
    <div class="xl:col-span-2 space-y-5">

        <!-- Complaint Info -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
            <h2 class="text-sm font-semibold text-gray-900 mb-4">ข้อมูลเรื่องร้องเรียน</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
                <div>
                    <dt class="text-xs text-gray-500 font-medium">ชื่อผู้ร้อง</dt>
                    <dd class="text-gray-900 mt-0.5">@c.ReporterName</dd>
                </div>
                <div>
                    <dt class="text-xs text-gray-500 font-medium">เบอร์โทรศัพท์</dt>
                    <dd class="text-gray-900 mt-0.5 font-mono">@c.ReporterPhone</dd>
                </div>
                @if (!string.IsNullOrEmpty(c.ReporterEmail))
                {
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">อีเมล</dt>
                        <dd class="text-gray-900 mt-0.5">@c.ReporterEmail</dd>
                    </div>
                }
                <div>
                    <dt class="text-xs text-gray-500 font-medium">ประเภทเรื่อง</dt>
                    <dd class="text-gray-900 mt-0.5">@c.Category.Name</dd>
                </div>
                @if (!string.IsNullOrEmpty(c.SubjectStation))
                {
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">สถานี / จุดที่เกิดเหตุ</dt>
                        <dd class="text-gray-900 mt-0.5">@c.SubjectStation</dd>
                    </div>
                }
                @if (c.IncidentDate.HasValue)
                {
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">วันที่เกิดเหตุ</dt>
                        <dd class="text-gray-900 mt-0.5">@c.IncidentDate.Value.ToString("dd/MM/yyyy")</dd>
                    </div>
                }
                <div>
                    <dt class="text-xs text-gray-500 font-medium">SLA Deadline</dt>
                    <dd class="mt-0.5 @(slaBreached ? "text-red-600 font-medium" : "text-gray-900")">
                        @(c.SlaDeadline.HasValue ? c.SlaDeadline.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")
                        @if (slaBreached) { <span class="ml-1">⚠</span> }
                    </dd>
                </div>
                <div>
                    <dt class="text-xs text-gray-500 font-medium">ผู้รับผิดชอบ</dt>
                    <dd class="text-gray-900 mt-0.5">@(c.AssignedTo?.FullName ?? "ยังไม่ได้รับมอบหมาย")</dd>
                </div>
            </dl>

            <div class="mt-4 pt-4 border-t border-gray-100">
                <dt class="text-xs text-gray-500 font-medium mb-1.5">รายละเอียดเรื่องร้องเรียน</dt>
                <dd class="text-gray-800 text-sm leading-relaxed bg-gray-50 rounded-lg p-3 whitespace-pre-wrap">@c.Description</dd>
            </div>
        </div>

        <!-- Attachments -->
        @if (c.Attachments.Any())
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                <h2 class="text-sm font-semibold text-gray-900 mb-3">ไฟล์แนบ</h2>
                <ul class="space-y-1.5">
                    @foreach (var att in c.Attachments)
                    {
                        <li class="flex items-center gap-2 text-sm">
                            <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13" />
                            </svg>
                            <span class="text-gray-700 flex-1 truncate">@att.FileName</span>
                            <span class="text-gray-400 text-xs shrink-0">@(att.FileSize / 1024) KB</span>
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- Timeline / Notes -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
            <h2 class="text-sm font-semibold text-gray-900 mb-4">ประวัติและบันทึก</h2>

            @if (!c.Notes.Any() && !c.TransferLogs.Any())
            {
                <p class="text-sm text-gray-400 text-center py-6">ยังไม่มีบันทึก</p>
            }

            <div class="space-y-4">
                @foreach (var note in c.Notes.OrderByDescending(n => n.CreatedAt))
                {
                    <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full bg-srt-navy/10 flex items-center justify-center text-xs font-semibold text-srt-navy shrink-0 mt-0.5">
                            @(note.Author?.FullName?.Split(' ').FirstOrDefault()?.FirstOrDefault() ?? '?')
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-sm font-medium text-gray-900">@(note.Author?.FullName ?? "ระบบ")</span>
                                <span class="px-1.5 py-0.5 rounded text-[10px] font-medium
                                             @(note.NoteType == "PublicReply" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-600")">
                                    @(note.NoteType == "PublicReply" ? "ตอบกลับผู้ร้อง" : "บันทึกภายใน")
                                </span>
                                <span class="text-xs text-gray-400 ml-auto">@note.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</span>
                            </div>
                            <p class="text-sm text-gray-700 bg-gray-50 rounded-lg px-3 py-2 whitespace-pre-wrap">@note.Content</p>
                        </div>
                    </div>
                }

                @foreach (var transfer in c.TransferLogs.OrderByDescending(t => t.TransferredAt))
                {
                    <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center shrink-0 mt-0.5">
                            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm text-gray-700">
                                โอนเรื่องไปยัง <strong>@(transfer.ToOfficer?.FullName ?? "—")</strong>
                                @if (transfer.FromOfficer != null) { <span> จาก @transfer.FromOfficer.FullName</span> }
                            </p>
                            <p class="text-xs text-gray-500 mt-0.5">เหตุผล: @transfer.Reason</p>
                            <p class="text-xs text-gray-400 mt-0.5">@transfer.TransferredAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</p>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ── Right: Action Panel ── -->
    <div class="space-y-4">

        <!-- Claim -->
        @if (c.AssignedToId == null && c.Status == "Pending")
        {
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
                <p class="text-sm text-amber-800 font-medium mb-3">ยังไม่มีผู้รับผิดชอบ</p>
                <form method="post" asp-page-handler="Claim" asp-route-id="@c.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full bg-srt-navy text-white text-sm font-medium py-2 rounded-lg
                                   hover:bg-srt-navy-dark transition">
                        รับเรื่องนี้
                    </button>
                </form>
            </div>
        }

        <!-- Update Status -->
        @if (!isClosed && Model.AllowedNextStatuses.Length > 0)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">อัปเดตสถานะ</h3>
                <form method="post" asp-page-handler="UpdateStatus" asp-route-id="@c.Id">
                    @Html.AntiForgeryToken()
                    <select name="NewStatus"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-3
                                   focus:outline-none focus:border-srt-navy">
                        <option value="">— เลือกสถานะใหม่ —</option>
                        @foreach (var status in Model.AllowedNextStatuses)
                        {
                            <option value="@status">@CaseDetailModel.StatusLabel(status)</option>
                        }
                    </select>
                    <button type="submit"
                            class="w-full border border-srt-navy text-srt-navy text-sm font-medium py-2 rounded-lg
                                   hover:bg-srt-navy hover:text-white transition">
                        บันทึกสถานะ
                    </button>
                </form>
            </div>
        }

        <!-- Add Note -->
        @if (!isClosed)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">เพิ่มบันทึก</h3>
                <form method="post" asp-page-handler="AddNote" asp-route-id="@c.Id">
                    @Html.AntiForgeryToken()
                    <div class="flex gap-2 mb-3">
                        <label class="flex items-center gap-1.5 text-xs text-gray-600 cursor-pointer">
                            <input type="radio" name="NoteType" value="InternalNote" checked class="accent-srt-navy" />
                            บันทึกภายใน
                        </label>
                        <label class="flex items-center gap-1.5 text-xs text-gray-600 cursor-pointer">
                            <input type="radio" name="NoteType" value="PublicReply" class="accent-srt-navy" />
                            ตอบกลับผู้ร้อง
                        </label>
                    </div>
                    <textarea name="NoteContent" rows="3"
                              placeholder="กรอกบันทึก..."
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-3
                                     focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                     resize-none"></textarea>
                    <button type="submit"
                            class="w-full border border-gray-300 text-gray-700 text-sm font-medium py-2 rounded-lg
                                   hover:bg-gray-50 transition">
                        บันทึก
                    </button>
                </form>
            </div>
        }

        <!-- Transfer -->
        @if (!isClosed && c.AssignedToId.HasValue && Model.StaffOptions.Any())
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">โอนเรื่อง</h3>
                <form method="post" asp-page-handler="Transfer" asp-route-id="@c.Id">
                    @Html.AntiForgeryToken()
                    <select name="TransferToId"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-2
                                   focus:outline-none focus:border-srt-navy">
                        <option value="">— เลือกผู้รับโอน —</option>
                        @foreach (var s in Model.StaffOptions)
                        {
                            <option value="@s.Value">@s.Text</option>
                        }
                    </select>
                    <input type="text" name="TransferReason" placeholder="เหตุผลในการโอน..."
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-3
                                  focus:outline-none focus:border-srt-navy" />
                    <button type="submit"
                            class="w-full border border-gray-300 text-gray-700 text-sm font-medium py-2 rounded-lg
                                   hover:bg-gray-50 transition">
                        โอนเรื่อง
                    </button>
                </form>
            </div>
        }

        <!-- Close -->
        @if (c.Status == "Resolved")
        {
            <div class="bg-white rounded-xl border border-red-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-red-700 mb-3">ปิดเรื่องร้องเรียน</h3>
                <form method="post" asp-page-handler="Close" asp-route-id="@c.Id">
                    @Html.AntiForgeryToken()
                    <textarea name="CloseResolution" rows="3" required
                              placeholder="สรุปการดำเนินการก่อนปิดเรื่อง (จำเป็น)..."
                              class="w-full border border-red-200 rounded-lg px-3 py-2 text-sm mb-3
                                     focus:outline-none focus:border-red-400 focus:ring-2 focus:ring-red-100
                                     resize-none"></textarea>
                    <button type="submit"
                            onclick="return confirm('ยืนยันการปิดเรื่องนี้?')"
                            class="w-full bg-red-600 text-white text-sm font-medium py-2 rounded-lg
                                   hover:bg-red-700 transition">
                        ปิดเรื่อง
                    </button>
                </form>
            </div>
        }

        <!-- Closed state info -->
        @if (isClosed)
        {
            <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-center">
                <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-sm text-gray-500">เรื่องนี้ปิดแล้ว</p>
                @if (c.ClosedAt.HasValue)
                {
                    <p class="text-xs text-gray-400 mt-1">@c.ClosedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                }
                @if (c.Status == "Closed")
                {
                    <form method="post" asp-page-handler="Reopen" asp-route-id="@c.Id" class="mt-3">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                onclick="return confirm('เปิดเรื่องนี้ใหม่อีกครั้ง?')"
                                class="inline-flex items-center gap-1.5 text-xs text-amber-700 border border-amber-300
                                       bg-amber-50 px-3 py-1.5 rounded-lg hover:bg-amber-100 transition">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                            เปิดเรื่องใหม่
                        </button>
                    </form>
                }
            </div>
        }

    </div>
</div>
