@page
@model SRT.Complaint.Pages.Staff.CreateComplaintModel
@{
    ViewData["Title"] = "สร้างเรื่องร้องเรียนใหม่";
    Layout = "_StaffLayout";
}

<div class="max-w-2xl mx-auto">

    <!-- Page Header -->
    <div class="flex items-center gap-3 mb-6">
        <a asp-page="/Staff/Queue" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <div>
            <h1 class="text-lg font-semibold text-gray-900">สร้างเรื่องร้องเรียนใหม่</h1>
            <p class="text-sm text-gray-500">บันทึกเรื่องร้องเรียนที่รับจากช่องทางอื่น เช่น โทรศัพท์ Facebook Line</p>
        </div>
    </div>

    <form method="post" class="space-y-5">
        @Html.AntiForgeryToken()

        <!-- ── ช่องทาง ── -->
        <div class="card p-5">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">ช่องทางที่รับเรื่อง</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="channel-grid">
                @foreach (var ch in CreateComplaintModel.ChannelOptions)
                {
                    var icon = ch.Value switch
                    {
                        "Phone"   => """<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>""",
                        "Facebook"=> """<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 2h-3a5 5 0 00-5 5v3H6v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>""",
                        "Line"    => """<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>""",
                        "Email"   => """<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>""",
                        "Walkin"  => """<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>""",
                        _         => """<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>"""
                    };
                    <label class="channel-card cursor-pointer">
                        <input type="radio" name="Input.Channel" value="@ch.Value"
                               class="sr-only peer"
                               @(ch.Value == "Phone" ? "checked" : "") />
                        <div class="flex flex-col items-center gap-2 p-3 rounded-xl border-2 border-gray-200
                                    peer-checked:border-srt-navy peer-checked:bg-srt-navy/5 transition">
                            <svg class="w-6 h-6 text-gray-500 peer-checked:text-srt-navy" fill="none"
                                 stroke="currentColor" viewBox="0 0 24 24">
                                @Html.Raw(icon)
                            </svg>
                            <span class="text-xs font-medium text-gray-700 text-center leading-tight">@ch.Text</span>
                        </div>
                    </label>
                }
            </div>
            <span asp-validation-for="Input.Channel" class="text-xs text-red-600 mt-1 block"></span>
        </div>

        <!-- ── ข้อมูลผู้ร้องเรียน ── -->
        <div class="card p-5">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">ข้อมูลผู้ร้องเรียน</h2>
            <div class="space-y-4">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Input.ReporterName" class="form-label">ชื่อ-นามสกุล <span class="text-red-500">*</span></label>
                        <input asp-for="Input.ReporterName" class="form-input" placeholder="ชื่อ นามสกุล" />
                        <span asp-validation-for="Input.ReporterName" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Input.ReporterPhone" class="form-label">เบอร์โทรศัพท์ <span class="text-red-500">*</span></label>
                        <input asp-for="Input.ReporterPhone" class="form-input" placeholder="08x-xxx-xxxx"
                               inputmode="tel" id="reporter-phone" />
                        <span asp-validation-for="Input.ReporterPhone" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Input.ReporterEmail" class="form-label">อีเมล <span class="text-gray-400">(ถ้ามี)</span></label>
                    <input asp-for="Input.ReporterEmail" type="email" class="form-input" placeholder="example@email.com" />
                    <span asp-validation-for="Input.ReporterEmail" class="text-xs text-red-600 mt-1 block"></span>
                </div>

            </div>
        </div>

        <!-- ── รายละเอียดเรื่องร้องเรียน ── -->
        <div class="card p-5">
            <h2 class="text-sm font-semibold text-gray-700 mb-4">รายละเอียดเรื่องร้องเรียน</h2>
            <div class="space-y-4">

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Input.CategoryId" class="form-label">ประเภทเรื่อง <span class="text-red-500">*</span></label>
                        <select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions"
                                id="category-select" class="form-input"
                                onchange="updateSubCategories(this.value)">
                            <option value="0">-- เลือกประเภท --</option>
                        </select>
                        <span asp-validation-for="Input.CategoryId" class="text-xs text-red-600 mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Input.SubCategoryId" class="form-label">หัวข้อย่อย <span class="text-gray-400">(ถ้ามี)</span></label>
                        <select asp-for="Input.SubCategoryId" id="sub-category-select" class="form-input" disabled>
                            <option value="">-- เลือกหัวข้อย่อย --</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Input.SubjectStation" class="form-label">สถานที่ / สถานี <span class="text-gray-400">(ถ้ามี)</span></label>
                        <input asp-for="Input.SubjectStation" class="form-input" placeholder="เช่น สถานีกรุงเทพ" />
                    </div>
                    <div>
                        <label asp-for="Input.IncidentDate" class="form-label">วัน/เวลาเกิดเหตุ <span class="text-gray-400">(ถ้ามี)</span></label>
                        <input asp-for="Input.IncidentDate" type="date" class="form-input" id="incident-date" />
                    </div>
                </div>

                <div>
                    <label asp-for="Input.Description" class="form-label">รายละเอียดคำร้อง <span class="text-red-500">*</span></label>
                    <textarea asp-for="Input.Description" class="form-input" rows="5"
                              placeholder="กรอกรายละเอียดเรื่องร้องเรียน..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-xs text-red-600 mt-1 block"></span>
                </div>

            </div>
        </div>

        <!-- ── Action ── -->
        <div class="flex items-center justify-end gap-3">
            <a asp-page="/Staff/Queue" class="btn-secondary">ยกเลิก</a>
            <button type="submit" class="btn-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 4v16m8-8H4" />
                </svg>
                สร้างเรื่องร้องเรียน
            </button>
        </div>

    </form>
</div>

@section Scripts {
<script>
    const subData = @Html.Raw(Model.SubCategoriesJson);

    function updateSubCategories(catId) {
        const sel = document.getElementById('sub-category-select');
        sel.innerHTML = '<option value="">-- เลือกหัวข้อย่อย --</option>';
        const items = subData[catId] || [];
        if (items.length === 0) {
            sel.disabled = true;
            return;
        }
        items.forEach(s => {
            const opt = new Option(s.Name, s.Id);
            sel.add(opt);
        });
        sel.disabled = false;
    }

    // phone mask
    document.getElementById('reporter-phone')?.addEventListener('input', function () {
        let v = this.value.replace(/\D/g, '').slice(0, 10);
        if (v.length > 6) v = v.slice(0,3) + '-' + v.slice(3,6) + '-' + v.slice(6);
        else if (v.length > 3) v = v.slice(0,3) + '-' + v.slice(3);
        this.value = v;
    });
    document.querySelector('form')?.addEventListener('submit', function () {
        const ph = document.getElementById('reporter-phone');
        if (ph) ph.value = ph.value.replace(/-/g, '');
    });

    // channel card styling — sync peer-checked via JS (radio peer needs sibling, workaround for label wrap)
    document.querySelectorAll('input[name="Input.Channel"]').forEach(r => {
        r.addEventListener('change', () => {
            document.querySelectorAll('input[name="Input.Channel"]').forEach(x => {
                x.closest('label').querySelector('div').classList.remove('border-srt-navy','bg-srt-navy/5');
                x.closest('label').querySelector('div').classList.add('border-gray-200');
            });
            r.closest('label').querySelector('div').classList.add('border-srt-navy','bg-srt-navy/5');
            r.closest('label').querySelector('div').classList.remove('border-gray-200');
        });
        if (r.checked) r.dispatchEvent(new Event('change'));
    });
</script>
}
