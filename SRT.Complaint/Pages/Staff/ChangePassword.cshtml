@page
@model SRT.Complaint.Pages.Staff.ChangePasswordModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "เปลี่ยนรหัสผ่าน";
}

<div class="min-h-screen bg-slate-100 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">

        <!-- Logo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-srt-navy mb-3">
                <span class="text-white font-black text-lg">รฟท.</span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">เปลี่ยนรหัสผ่าน</h1>
            @if (Model.IsForced)
            {
                <p class="mt-2 text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-4 py-2 mt-3">
                    กรุณาเปลี่ยนรหัสผ่านก่อนใช้งานระบบ
                </p>
            }
            else
            {
                <p class="mt-2 text-sm text-gray-500">อัปเดตรหัสผ่านของคุณ</p>
            }
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mb-5 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">
                            รหัสผ่านปัจจุบัน
                            @if (Model.IsForced)
                            {
                                <span class="text-xs text-gray-400 font-normal">(รหัสผ่านชั่วคราวที่ได้รับ)</span>
                            }
                        </label>
                        <input asp-for="CurrentPassword" type="password" autocomplete="current-password"
                               data-block="thai"
                               class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-srt-navy focus:ring-1 focus:ring-srt-navy" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">รหัสผ่านใหม่</label>
                        <input asp-for="NewPassword" id="newPasswordInput" type="password" autocomplete="new-password"
                               data-block="thai"
                               class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-srt-navy focus:ring-1 focus:ring-srt-navy"
                               oninput="checkPasswordStrength(this.value)" />
                        <!-- Password strength checklist -->
                        <div id="pwChecklist" class="mt-2 p-3 bg-gray-50 rounded-xl border border-gray-200 hidden">
                            <p class="text-xs font-medium text-gray-600 mb-1.5">รหัสผ่านต้องมี:</p>
                            <ul class="space-y-1 text-xs">
                                <li id="pw-len"     class="flex items-center gap-1.5 text-gray-400"><span class="font-bold">✗</span> อย่างน้อย 8 ตัวอักษร</li>
                                <li id="pw-upper"   class="flex items-center gap-1.5 text-gray-400"><span class="font-bold">✗</span> ตัวพิมพ์ใหญ่ (A-Z)</li>
                                <li id="pw-lower"   class="flex items-center gap-1.5 text-gray-400"><span class="font-bold">✗</span> ตัวพิมพ์เล็ก (a-z)</li>
                                <li id="pw-digit"   class="flex items-center gap-1.5 text-gray-400"><span class="font-bold">✗</span> ตัวเลข (0-9)</li>
                                <li id="pw-special" class="flex items-center gap-1.5 text-gray-400"><span class="font-bold">✗</span> อักขระพิเศษ (!@@#$%...)</li>
                                <li id="pw-thai"    class="flex items-center gap-1.5 text-gray-400"><span class="font-bold">✓</span> ไม่มีภาษาไทย</li>
                            </ul>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">ยืนยันรหัสผ่านใหม่</label>
                        <input asp-for="ConfirmPassword" type="password" autocomplete="new-password"
                               data-block="thai"
                               class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-srt-navy focus:ring-1 focus:ring-srt-navy" />
                    </div>
                </div>

                <button type="submit"
                        class="mt-6 w-full bg-srt-navy text-white py-3 px-4 rounded-xl text-sm font-semibold hover:bg-srt-navy-dark transition focus:outline-none focus:ring-2 focus:ring-srt-navy focus:ring-offset-2">
                    เปลี่ยนรหัสผ่าน
                </button>

                @if (!Model.IsForced)
                {
                    <div class="mt-4 text-center">
                        <a asp-page="/Staff/Dashboard" class="text-sm text-gray-500 hover:text-srt-navy transition">
                            ← กลับแดชบอร์ด
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

<script>
function checkPasswordStrength(val) {
    const list = document.getElementById('pwChecklist');
    if (!list) return;
    list.classList.toggle('hidden', val.length === 0);

    const set = (id, ok) => {
        const li = document.getElementById(id);
        if (!li) return;
        li.querySelector('span').textContent = ok ? '✓' : '✗';
        li.className = 'flex items-center gap-1.5 text-xs ' + (ok ? 'text-green-600' : 'text-red-500');
    };

    const hasThai = /[฀-๿]/.test(val);
    set('pw-len',     val.length >= 8);
    set('pw-upper',   /[A-Z]/.test(val));
    set('pw-lower',   /[a-z]/.test(val));
    set('pw-digit',   /[0-9]/.test(val));
    set('pw-special', /[^A-Za-z0-9]/.test(val));
    set('pw-thai',    !hasThai);
}
</script>
