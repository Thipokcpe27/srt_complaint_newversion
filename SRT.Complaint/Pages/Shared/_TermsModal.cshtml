@model SRT.Complaint.Models.ComplaintTerms?

@if (Model is { IsActive: true })
{
    <div id="terms-overlay"
         class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4"
         role="dialog"
         aria-modal="true"
         aria-labelledby="terms-title">
        <div class="bg-white rounded-2xl shadow-2xl w-full mx-auto flex flex-col"
             style="max-width: 680px; max-height: 88vh;">

            <!-- Header -->
            <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3 shrink-0">
                <div class="w-10 h-10 bg-srt-navy rounded-xl flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                </div>
                <div class="min-w-0">
                    <h2 id="terms-title" class="text-base font-bold text-gray-900">@Model.Title</h2>
                    <p class="text-xs text-gray-500 mt-0.5">กรุณาอ่านและยอมรับก่อนดำเนินการยื่นเรื่อง</p>
                </div>
            </div>

            <!-- Scrollable content -->
            <div class="flex-1 overflow-y-auto px-6 py-5 leading-relaxed">
                @Html.Raw(Model.Content)
            </div>

            <!-- Footer -->
            <div class="px-6 py-4 border-t border-gray-100 bg-gray-50 rounded-b-2xl shrink-0">
                <label class="flex items-start gap-3 cursor-pointer mb-4 select-none">
                    <input type="checkbox"
                           id="terms-checkbox"
                           class="mt-0.5 w-4 h-4 rounded border-gray-300 text-srt-navy cursor-pointer"
                           onchange="document.getElementById('terms-accept-btn').disabled = !this.checked" />
                    <span class="text-sm text-gray-700">
                        ข้าพเจ้าได้อ่านและ<strong class="text-gray-900">ยอมรับหลักเกณฑ์การรับเรื่องร้องเรียน</strong>ของการรถไฟแห่งประเทศไทยทุกข้อ
                    </span>
                </label>
                <div class="flex gap-3">
                    <a href="/"
                       class="flex-1 text-center px-4 py-2.5 border border-gray-300 text-gray-700 text-sm
                              font-medium rounded-xl hover:bg-gray-100 transition">
                        ยกเลิก / กลับหน้าแรก
                    </a>
                    <button type="button"
                            id="terms-accept-btn"
                            disabled
                            onclick="onTermsAccepted()"
                            class="flex-1 px-4 py-2.5 bg-srt-navy text-white text-sm font-semibold rounded-xl
                                   transition disabled:opacity-40 disabled:cursor-not-allowed
                                   enabled:hover:bg-blue-900">
                        <svg class="w-4 h-4 inline mr-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        ยอมรับและดำเนินการต่อ
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function onTermsAccepted() {
            document.getElementById('terms-overlay').style.display = 'none';
            var wrapper = document.getElementById('form-content-wrapper');
            if (wrapper) {
                wrapper.classList.remove('hidden');
                wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }
    </script>
}
