<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ระบบรับเรื่องร้องเรียนออนไลน์ การรถไฟแห่งประเทศไทย" />
    <title>@ViewData["Title"] — ระบบรับเรื่องร้องเรียน รฟท.</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="min-h-screen flex flex-col bg-gray-50 font-thai antialiased">

    <!-- TOP NAVBAR -->
    <header>
        <nav class="bg-srt-navy text-white shadow-lg" role="navigation" aria-label="เมนูหลัก">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">

                    <!-- Brand -->
                    <a asp-page="/Public/Index" class="flex items-center gap-3 group shrink-0">
                        <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm ring-2 ring-white/30 group-hover:ring-white/60 transition">
                            <span class="text-srt-navy font-black text-[10px] leading-none tracking-tight">รฟท.</span>
                        </div>
                        <div class="leading-tight">
                            <div class="font-semibold text-sm">การรถไฟแห่งประเทศไทย</div>
                            <div class="text-blue-200 text-xs">ระบบรับเรื่องร้องเรียน</div>
                        </div>
                    </a>

                    <!-- Desktop nav -->
                    <div class="hidden md:flex items-center gap-1">
                        <a asp-page="/Public/Index"
                           class="px-3 py-2 rounded-lg text-sm hover:bg-white/10 transition">หน้าแรก</a>
                        <a asp-page="/Public/Submit"
                           class="px-3 py-2 rounded-lg text-sm hover:bg-white/10 transition">ยื่นเรื่องร้องเรียน</a>
                        <a asp-page="/Public/SubmitCorruption"
                           class="px-3 py-2 rounded-lg text-sm hover:bg-white/10 transition">แจ้งเบาะแสทุจริต</a>
                        <a asp-page="/Public/Track"
                           class="px-3 py-2 rounded-lg text-sm hover:bg-white/10 transition">ติดตามสถานะ</a>
                        <a asp-page="/Staff/Login"
                           class="ml-4 px-4 py-1.5 text-sm border border-white/40 rounded-full hover:bg-white hover:text-srt-navy transition font-medium">
                            เข้าสู่ระบบ
                        </a>
                    </div>

                    <!-- Mobile burger -->
                    <button type="button"
                            onclick="document.getElementById('mobile-nav').classList.toggle('hidden')"
                            class="md:hidden p-2 rounded-lg hover:bg-white/10 transition"
                            aria-controls="mobile-nav"
                            aria-label="เปิด/ปิดเมนู">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile menu -->
            <div id="mobile-nav" class="hidden md:hidden border-t border-white/20 bg-srt-navy-dark">
                <div class="px-4 py-3 space-y-1">
                    <a asp-page="/Public/Index"
                       class="block px-3 py-2.5 rounded-lg text-sm hover:bg-white/10 transition">หน้าแรก</a>
                    <a asp-page="/Public/Submit"
                       class="block px-3 py-2.5 rounded-lg text-sm hover:bg-white/10 transition">ยื่นเรื่องร้องเรียน</a>
                    <a asp-page="/Public/SubmitCorruption"
                       class="block px-3 py-2.5 rounded-lg text-sm hover:bg-white/10 transition">แจ้งเบาะแสทุจริต</a>
                    <a asp-page="/Public/Track"
                       class="block px-3 py-2.5 rounded-lg text-sm hover:bg-white/10 transition">ติดตามสถานะ</a>
                    <hr class="border-white/20 my-2" />
                    <a asp-page="/Staff/Login"
                       class="block px-3 py-2.5 rounded-lg text-sm hover:bg-white/10 transition font-medium">
                        เข้าสู่ระบบเจ้าหน้าที่
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <!-- FLASH MESSAGES -->
    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert-success mx-4 mt-4 max-w-7xl md:mx-auto" role="alert">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>@successMsg</span>
        </div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert-error mx-4 mt-4 max-w-7xl md:mx-auto" role="alert">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-1-9a1 1 0 012 0v4a1 1 0 01-2 0V9zm0 6a1 1 0 112 0 1 1 0 01-2 0z" clip-rule="evenodd" />
            </svg>
            <span>@errorMsg</span>
        </div>
    }
    @if (TempData["Warning"] is string warnMsg)
    {
        <div class="alert-warning mx-4 mt-4 max-w-7xl md:mx-auto" role="alert">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <span>@warnMsg</span>
        </div>
    }

    <!-- MAIN CONTENT -->
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8" id="main-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-srt-navy text-white mt-auto" role="contentinfo">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
                <div>
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-9 h-9 bg-white rounded-full flex items-center justify-center shrink-0">
                            <span class="text-srt-navy font-black text-[10px]">รฟท.</span>
                        </div>
                        <span class="font-semibold text-sm">การรถไฟแห่งประเทศไทย</span>
                    </div>
                    <p class="text-blue-200 text-sm leading-relaxed">
                        ระบบรับเรื่องร้องเรียนออนไลน์<br />
                        เพื่อยกระดับการให้บริการ
                    </p>
                </div>
                <div>
                    <h3 class="font-semibold mb-3 text-sm">บริการของเรา</h3>
                    <ul class="space-y-2 text-blue-200 text-sm">
                        <li>
                            <a asp-page="/Public/Submit"
                               class="hover:text-white transition inline-flex items-center gap-1.5">
                                <span class="w-1.5 h-1.5 bg-srt-gold rounded-full shrink-0"></span>
                                ยื่นเรื่องร้องเรียนทั่วไป
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Public/SubmitCorruption"
                               class="hover:text-white transition inline-flex items-center gap-1.5">
                                <span class="w-1.5 h-1.5 bg-srt-gold rounded-full shrink-0"></span>
                                แจ้งเบาะแสทุจริต
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Public/Track"
                               class="hover:text-white transition inline-flex items-center gap-1.5">
                                <span class="w-1.5 h-1.5 bg-srt-gold rounded-full shrink-0"></span>
                                ติดตามสถานะ
                            </a>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3 class="font-semibold mb-3 text-sm">ติดต่อ รฟท.</h3>
                    <address class="text-blue-200 text-sm not-italic leading-relaxed">
                        การรถไฟแห่งประเทศไทย<br />
                        1 ถ.รองเมือง แขวงรองเมือง<br />
                        เขตปทุมวัน กรุงเทพฯ 10330<br />
                        <a href="tel:1690" class="hover:text-white transition mt-1 inline-block">
                            ☎ 1690
                        </a>
                    </address>
                </div>
            </div>

            <div class="mt-8 pt-6 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-3">
                <p class="text-blue-200 text-xs">
                    &copy; พ.ศ. @(DateTime.UtcNow.Year + 543) การรถไฟแห่งประเทศไทย — สงวนลิขสิทธิ์
                </p>
                <a asp-page="/Privacy" class="text-blue-200 text-xs hover:text-white transition">
                    นโยบายความเป็นส่วนตัว
                </a>
            </div>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/htmx.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
