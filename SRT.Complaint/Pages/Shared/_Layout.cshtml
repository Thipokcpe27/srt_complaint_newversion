<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ระบบรับเรื่องร้องเรียนออนไลน์ การรถไฟแห่งประเทศไทย" />
    <title>@ViewData["Title"] — ระบบรับเรื่องร้องเรียน รฟท.</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="min-h-screen flex flex-col bg-gray-50 font-thai antialiased">

    <!-- Skip navigation — WCAG 2.4.1 -->
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[9999]
              focus:bg-srt-navy focus:text-white focus:px-4 focus:py-2 focus:rounded-lg
              focus:text-sm focus:font-semibold focus:shadow-lg">
        ข้ามไปยังเนื้อหาหลัก
    </a>

    <!-- ═══ NAVBAR ═══ -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-100 shadow-sm">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" role="navigation" aria-label="เมนูหลัก">
            <div class="flex items-center justify-between h-16">

                <!-- Brand -->
                <a href="/" class="flex items-center gap-3 group shrink-0">
                    <img src="~/images/srt-logo.png"
                         alt="การรถไฟแห่งประเทศไทย"
                         class="h-12 w-auto object-contain transition-transform duration-200 group-hover:scale-105" />
                    <div class="leading-tight hidden sm:block">
                        <div class="text-gray-400 text-[11px] font-medium">ระบบรับเรื่องร้องเรียน</div>
                    </div>
                </a>

                <!-- Desktop nav -->
                <div class="hidden md:flex items-center gap-1 bg-gray-100 rounded-full px-1.5 py-1.5">
                    <a href="/"
                       class="nav-pill hover:bg-white hover:shadow-sm hover:text-gray-900 text-gray-600">หน้าแรก</a>
                    <a asp-page="/Public/Submit"
                       class="nav-pill hover:bg-white hover:shadow-sm hover:text-gray-900 text-gray-600">ยื่นเรื่องร้องเรียน</a>
                    <a asp-page="/Public/SubmitCorruption"
                       class="nav-pill hover:bg-white hover:shadow-sm hover:text-amber-700 text-gray-600">แจ้งทุจริต</a>
                    <a asp-page="/Public/Track"
                       class="nav-pill hover:bg-white hover:shadow-sm hover:text-gray-900 text-gray-600">ติดตามสถานะ</a>
                </div>

                <div class="flex items-center gap-2">
                    <a asp-page="/Staff/Login"
                       class="hidden md:inline-flex items-center gap-2 btn-primary btn-sm">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        เจ้าหน้าที่
                    </a>

                    <!-- Mobile burger -->
                    <button type="button"
                            id="mobile-menu-btn"
                            onclick="toggleMobileNav()"
                            class="md:hidden p-2 rounded-xl hover:bg-gray-100 text-gray-600 transition focus:outline-none focus:ring-2 focus:ring-srt-navy focus:ring-offset-1"
                            aria-controls="mobile-nav"
                            aria-expanded="false"
                            aria-label="เปิดเมนู">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </nav>

        <!-- Mobile menu -->
        <div id="mobile-nav" class="hidden md:hidden border-t border-gray-100 bg-white/98 backdrop-blur-md">
            <div class="px-4 py-3 space-y-1">
                <a href="/" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-gray-50 font-medium transition">หน้าแรก</a>
                <a asp-page="/Public/Submit" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-gray-50 font-medium transition">ยื่นเรื่องร้องเรียน</a>
                <a asp-page="/Public/SubmitCorruption" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-amber-700 hover:bg-amber-50 font-medium transition">แจ้งเบาะแสทุจริต</a>
                <a asp-page="/Public/Track" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-gray-700 hover:bg-gray-50 font-medium transition">ติดตามสถานะ</a>
                <div class="pt-2 border-t border-gray-100">
                    <a asp-page="/Staff/Login" class="btn-primary w-full justify-center mt-1">เข้าสู่ระบบเจ้าหน้าที่</a>
                </div>
            </div>
        </div>
    </header>

    <!-- FLASH MESSAGES -->
    @if (TempData["Success"] is string successMsg)
    {
        <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-4 animate-fade-in" role="alert">
            <div class="alert-success">
                <svg class="w-4 h-4 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span>@successMsg</span>
            </div>
        </div>
    }
    @if (TempData["Error"] is string errorMsg)
    {
        <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-4 animate-fade-in" role="alert">
            <div class="alert-error">
                <svg class="w-4 h-4 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm-1-9a1 1 0 012 0v4a1 1 0 01-2 0V9zm0 6a1 1 0 112 0 1 1 0 01-2 0z" clip-rule="evenodd" />
                </svg>
                <span>@errorMsg</span>
            </div>
        </div>
    }
    @if (TempData["Warning"] is string warnMsg)
    {
        <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-4 animate-fade-in" role="alert">
            <div class="alert-warning">
                <svg class="w-4 h-4 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
                <span>@warnMsg</span>
            </div>
        </div>
    }

    <!-- MAIN CONTENT -->
    <main class="flex-1" id="main-content">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-srt-navy text-white mt-auto" role="contentinfo">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
                <div>
                    <div class="mb-4">
                        <img src="~/images/srt-logo.png"
                             alt="การรถไฟแห่งประเทศไทย"
                             class="h-20 w-auto object-contain"
                             style="filter: brightness(0) invert(1);" />
                    </div>
                    <p class="text-slate-400 text-sm leading-relaxed">
                        ระบบรับเรื่องร้องเรียนออนไลน์<br />เพื่อยกระดับการให้บริการ
                    </p>
                </div>
                <div>
                    <h3 class="font-bold text-xs uppercase tracking-widest text-slate-400 mb-4">บริการ</h3>
                    <ul class="space-y-2.5 text-sm">
                        <li>
                            <a asp-page="/Public/Submit" class="text-slate-300 hover:text-white transition inline-flex items-center gap-2">
                                <span class="w-1.5 h-1.5 bg-srt-gold rounded-full shrink-0"></span>
                                ยื่นเรื่องร้องเรียนทั่วไป
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Public/SubmitCorruption" class="text-slate-300 hover:text-white transition inline-flex items-center gap-2">
                                <span class="w-1.5 h-1.5 bg-amber-400 rounded-full shrink-0"></span>
                                แจ้งเบาะแสทุจริต
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Public/Track" class="text-slate-300 hover:text-white transition inline-flex items-center gap-2">
                                <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full shrink-0"></span>
                                ติดตามสถานะเรื่อง
                            </a>
                        </li>
                    </ul>
                </div>
                <div>
                    <h3 class="font-bold text-xs uppercase tracking-widest text-slate-400 mb-4">ติดต่อ</h3>
                    <address class="text-slate-300 text-sm not-italic leading-relaxed">
                        การรถไฟแห่งประเทศไทย<br />
                        1 ถ.รองเมือง แขวงรองเมือง<br />
                        เขตปทุมวัน กรุงเทพฯ 10330
                        <a href="tel:1690" class="flex items-center gap-2 mt-3 text-srt-gold hover:text-srt-gold-light transition font-semibold">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                            </svg>
                            1690
                        </a>
                    </address>
                </div>
            </div>

            <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-3">
                <p class="text-slate-500 text-xs">
                    &copy; พ.ศ. @(DateTime.UtcNow.Year + 543) การรถไฟแห่งประเทศไทย — สงวนลิขสิทธิ์
                </p>
                <a asp-page="/Privacy" class="text-slate-500 text-xs hover:text-slate-300 transition">
                    นโยบายความเป็นส่วนตัว
                </a>
            </div>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/htmx.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    <script>
        function toggleMobileNav() {
            const nav = document.getElementById('mobile-nav');
            const btn = document.getElementById('mobile-menu-btn');
            const isHidden = nav.classList.toggle('hidden');
            btn.setAttribute('aria-expanded', String(!isHidden));
            btn.setAttribute('aria-label', isHidden ? 'เปิดเมนู' : 'ปิดเมนู');
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <partial name="_CookieBanner" />
</body>
</html>
