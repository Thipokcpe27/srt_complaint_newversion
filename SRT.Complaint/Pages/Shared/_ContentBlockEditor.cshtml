@{
    var prefix    = ViewData["Prefix"]?.ToString() ?? "";
    var title     = ViewData["Title"]?.ToString() ?? "";
    var body      = ViewData["Body"]?.ToString() ?? "";
    var label     = ViewData["Label"]?.ToString() ?? "";
    var hint      = ViewData["Hint"]?.ToString() ?? "";
    var updatedAt = ViewData["UpdatedAt"] is DateTime dt && dt != DateTime.MinValue
                    ? dt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    : "ยังไม่เคยบันทึก";
}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <div>
            <h2 class="font-semibold text-gray-900 text-sm">@label</h2>
            <p class="text-xs text-gray-400 mt-0.5">อัปเดตล่าสุด: @updatedAt</p>
        </div>
    </div>
    <div class="p-5 space-y-4">

        <!-- Title -->
        <div>
            <label class="form-label">หัวข้อ Popup</label>
            <input type="text"
                   name="@(prefix).Title"
                   id="@(prefix)_Title"
                   value="@title"
                   class="form-input"
                   placeholder="หัวข้อที่แสดงบน popup" />
        </div>

        <!-- Body editor with tabs -->
        <div>
            <div class="flex items-center justify-between mb-2">
                <label class="form-label mb-0">เนื้อหา (HTML)</label>
                <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
                    <button type="button"
                            id="@(prefix)-tab-edit"
                            onclick="switchEditorTab('@prefix', 'edit')"
                            class="px-3 py-1 text-xs font-medium rounded-md transition bg-white shadow-sm text-gray-900">
                        แก้ไข
                    </button>
                    <button type="button"
                            id="@(prefix)-tab-preview"
                            onclick="switchEditorTab('@prefix', 'preview')"
                            class="px-3 py-1 text-xs font-medium rounded-md transition text-gray-500 hover:text-gray-700">
                        ตัวอย่าง
                    </button>
                </div>
            </div>

            <div id="@(prefix)-editor">
                <textarea name="@(prefix).Body"
                          id="@(prefix)_Body"
                          rows="14"
                          class="w-full font-mono text-xs border border-gray-300 rounded-xl px-3 py-3
                                 focus:outline-none focus:ring-2 focus:ring-srt-navy/30 focus:border-srt-navy
                                 resize-y bg-gray-50">@body</textarea>
                @if (!string.IsNullOrEmpty(hint))
                {
                    <p class="text-xs text-gray-400 mt-1.5">@Html.Raw(hint)</p>
                }
            </div>

            <div id="@(prefix)-preview" class="hidden">
                <div id="@(prefix)-preview-content"
                     class="min-h-[180px] border border-gray-200 rounded-xl px-5 py-4
                            bg-white text-sm text-gray-700 leading-relaxed">
                </div>
                <p class="text-xs text-gray-400 mt-1.5">
                    ตัวอย่างข้อความ — CSS classes ของหน้าแรกจะไม่ทำงานใน preview นี้
                </p>
            </div>
        </div>
    </div>
</div>
