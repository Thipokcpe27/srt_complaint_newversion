@page
@model SRT.Complaint.Pages.Admin.AuditLogModel
@{
    ViewData["Title"] = "Audit Log";
}

<!-- ══ Filter Bar ══ -->
<form method="get" class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 mb-5">
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-3">
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Action</label>
            <input name="actionFilter" value="@Model.ActionFilter" placeholder="เช่น CreateStaffUser"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy" />
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">รหัสพนักงาน</label>
            <input name="actorCodeFilter" value="@Model.ActorCodeFilter" placeholder="0000000" maxlength="7"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-srt-navy" />
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Entity Type</label>
            <select name="entityTypeFilter"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy">
                <option value="">ทั้งหมด</option>
                @foreach (var et in Model.DistinctEntityTypes)
                {
                    <option value="@et" selected="@(Model.EntityTypeFilter == et)">@et</option>
                }
            </select>
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">จากวันที่</label>
            <input name="fromDate" type="date" value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                   data-datepicker
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy" />
        </div>
        <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">ถึงวันที่</label>
            <div class="flex gap-2">
                <input name="toDate" type="date" value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                       data-datepicker
                       class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy" />
                <button type="submit"
                        class="bg-srt-navy text-white px-3 py-2 rounded-lg text-sm font-medium hover:bg-srt-navy-dark transition">
                    กรอง
                </button>
            </div>
        </div>
    </div>
    <div class="flex items-center justify-between mt-3">
        @if (!string.IsNullOrEmpty(Model.ActionFilter) || !string.IsNullOrEmpty(Model.ActorCodeFilter) ||
             !string.IsNullOrEmpty(Model.EntityTypeFilter) || Model.FromDate.HasValue || Model.ToDate.HasValue)
        {
            <a asp-page="/Admin/AuditLog" class="text-xs text-gray-500 hover:text-gray-700">ล้างตัวกรอง</a>
        }
        else
        {
            <span></span>
        }
        <span class="text-sm text-gray-500">
            ทั้งหมด <strong class="text-gray-900">@Model.TotalCount.ToString("N0")</strong> รายการ
        </span>
    </div>
</form>

<!-- Export form -->
<form method="post" asp-page-handler="Export" class="mb-4">
    @Html.AntiForgeryToken()
    <input type="hidden" name="ActionFilter" value="@Model.ActionFilter" />
    <input type="hidden" name="ActorCodeFilter" value="@Model.ActorCodeFilter" />
    <input type="hidden" name="EntityTypeFilter" value="@Model.EntityTypeFilter" />
    <input type="hidden" name="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
    <input type="hidden" name="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
    <button type="submit"
            class="inline-flex items-center gap-1.5 text-xs text-green-700 border border-green-300 px-3 py-1.5 rounded-lg hover:bg-green-50 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Export Excel
    </button>
</form>

<!-- ══ Log Table ══ -->
<div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm bg-white mb-4">
    <table class="w-full text-sm border-collapse">
        <thead>
            <tr class="bg-gray-50 text-gray-600 text-left text-xs">
                <th class="px-4 py-3 font-semibold border-b border-gray-200 whitespace-nowrap">เวลา</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">Action</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">ผู้กระทำ</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">Entity</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">รายละเอียด</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">IP</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Logs.Any())
            {
                <tr>
                    <td colspan="6" class="px-4 py-12 text-center text-gray-400 text-sm">ไม่พบข้อมูล</td>
                </tr>
            }
            @foreach (var log in Model.Logs)
            {
                <tr class="hover:bg-gray-50/50 border-b border-gray-100 last:border-b-0">
                    <td class="px-4 py-2.5 text-gray-400 text-xs whitespace-nowrap font-mono">
                        @log.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm:ss")
                    </td>
                    <td class="px-4 py-2.5">
                        <span class="text-xs font-medium
                            @(log.Action.StartsWith("Create") || log.Action.StartsWith("Add") || log.Action.StartsWith("Claim") ? "text-green-700" :
                              log.Action.StartsWith("Delete") || log.Action.StartsWith("Revoke") || log.Action.StartsWith("Deactivate") ? "text-red-700" :
                              log.Action.StartsWith("Edit") || log.Action.StartsWith("Update") || log.Action.StartsWith("Reset") || log.Action.StartsWith("Transfer") ? "text-amber-700" :
                                                                "text-gray-700")">
                            @AuditLogModel.FormatAction(log.Action)
                        </span>
                    </td>
                    <td class="px-4 py-2.5 text-xs">
                        @if (log.ActorId.HasValue)
                        {
                            <div class="font-medium text-gray-900">
                                @(Model.ActorNames.GetValueOrDefault(log.ActorId.Value, log.ActorCode ?? "-"))
                            </div>
                            @if (!string.IsNullOrEmpty(log.ActorCode))
                            {
                                <div class="text-gray-400 font-mono">@log.ActorCode</div>
                            }
                        }
                        else
                        {
                            <span class="text-gray-400 italic">ระบบ</span>
                        }
                    </td>
                    <td class="px-4 py-2.5 text-xs text-gray-600">
                        @if (!string.IsNullOrEmpty(log.EntityType))
                        {
                            <span>@AuditLogModel.EntityTypeLabel(log.EntityType)</span>
                            @if (!string.IsNullOrEmpty(log.EntityId))
                            {
                                <text> <span class="text-gray-400">#@log.EntityId</span></text>
                            }
                        }
                    </td>
                    <td class="px-4 py-2.5 text-xs text-gray-600 max-w-[260px]">
                        @{
                            var detailText = AuditLogModel.FormatDetail(log.Action, log.Detail);
                        }
                        @if (!string.IsNullOrEmpty(detailText))
                        {
                            <span class="truncate block" title="@detailText">@detailText</span>
                        }
                    </td>
                    <td class="px-4 py-2.5 text-xs text-gray-400 font-mono whitespace-nowrap">
                        @(log.IpAddress ?? "—")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ══ Pagination ══ -->
@if (Model.TotalPages > 1)
{
    <div class="flex items-center justify-between">
        <p class="text-sm text-gray-500">แสดง @Model.PageStart–@Model.PageEnd จาก @Model.TotalCount.ToString("N0") รายการ</p>
        <div class="flex gap-1">
            @if (Model.CurrentPage > 1)
            {
                <a asp-page="/Admin/AuditLog" asp-route-currentPage="@(Model.CurrentPage-1)"
                   asp-route-actionFilter="@Model.ActionFilter" asp-route-actorCodeFilter="@Model.ActorCodeFilter"
                   asp-route-entityTypeFilter="@Model.EntityTypeFilter"
                   asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">← ก่อนหน้า</a>
            }
            @for (int p = Math.Max(1, Model.CurrentPage - 2); p <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); p++)
            {
                <a asp-page="/Admin/AuditLog" asp-route-currentPage="@p"
                   asp-route-actionFilter="@Model.ActionFilter" asp-route-actorCodeFilter="@Model.ActorCodeFilter"
                   asp-route-entityTypeFilter="@Model.EntityTypeFilter"
                   asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="px-3 py-1.5 text-sm rounded-lg @(p == Model.CurrentPage ? "bg-srt-navy text-white" : "border border-gray-300 hover:bg-gray-50")">@p</a>
            }
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-page="/Admin/AuditLog" asp-route-currentPage="@(Model.CurrentPage+1)"
                   asp-route-actionFilter="@Model.ActionFilter" asp-route-actorCodeFilter="@Model.ActorCodeFilter"
                   asp-route-entityTypeFilter="@Model.EntityTypeFilter"
                   asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")" asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                   class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">ถัดไป →</a>
            }
        </div>
    </div>
}
