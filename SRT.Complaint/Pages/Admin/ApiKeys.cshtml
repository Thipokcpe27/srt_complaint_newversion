@page
@model SRT.Complaint.Pages.Admin.ApiKeysModel
@{
    ViewData["Title"] = "API Keys";
}

<!-- ══ Show New Raw Key Once ══ -->
@if (TempData["NewRawKey"] is string rawKey)
{
    <div class="bg-green-50 border border-green-300 rounded-xl p-5 mb-5">
        <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <div class="flex-1">
                <p class="text-sm font-semibold text-green-800 mb-2">
                    สร้าง "@TempData["NewKeyName"]" เรียบร้อย — <strong>คัดลอก Key นี้ไว้ก่อน จะไม่สามารถดูได้อีก</strong>
                </p>
                <div class="flex items-center gap-2 bg-white border border-green-200 rounded-lg px-4 py-2.5">
                    <code id="rawKeyText" class="font-mono text-sm text-gray-800 flex-1 break-all select-all">@rawKey</code>
                    <button type="button"
                            onclick="navigator.clipboard.writeText(document.getElementById('rawKeyText').textContent); this.textContent='คัดลอกแล้ว ✓'"
                            class="text-xs text-green-700 font-medium hover:text-green-900 shrink-0 whitespace-nowrap">
                        คัดลอก
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ══ API Keys Table ══ -->
<div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm bg-white mb-6">
    <table class="w-full text-sm border-collapse">
        <thead>
            <tr class="bg-gray-50 text-gray-600 text-left text-xs">
                <th class="px-4 py-3 font-semibold border-b border-gray-200">ชื่อ / Prefix</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">ประเภท</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">Scopes</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">Rate Limit</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">IP Whitelist</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">หมดอายุ</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">ใช้ล่าสุด</th>
                <th class="px-4 py-3 font-semibold border-b border-gray-200">สถานะ</th>
                <th class="px-4 py-3 border-b border-gray-200 w-28"></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Keys.Any())
            {
                <tr>
                    <td colspan="9" class="px-4 py-12 text-center text-gray-400 text-sm">ยังไม่มี API Key</td>
                </tr>
            }
            @foreach (var k in Model.Keys)
            {
                <tr class="hover:bg-gray-50/50 border-b border-gray-100 last:border-b-0 @(!k.IsActive ? "opacity-50" : "")">
                    <td class="px-4 py-3">
                        <div class="font-medium text-gray-900">@k.Name</div>
                        <div class="font-mono text-xs text-gray-400">@k.KeyPrefix…</div>
                    </td>
                    <td class="px-4 py-3">
                        <span class="px-2 py-0.5 rounded-full text-xs font-medium
                            @(k.KeyType == "Internal" ? "bg-blue-100 text-blue-800" : "bg-gray-100 text-gray-700")">
                            @k.KeyType
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex flex-wrap gap-1">
                            @foreach (var scope in k.Scopes)
                            {
                                <span class="px-1.5 py-0.5 rounded text-[10px] font-mono font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
                                    @scope.Scope
                                </span>
                            }
                        </div>
                    </td>
                    <td class="px-4 py-3 text-xs text-gray-600">@k.RateLimitPerMin req/min</td>
                    <td class="px-4 py-3 text-xs text-gray-500 font-mono">
                        @if (string.IsNullOrEmpty(k.AllowedIps))
                        {
                            <span class="text-gray-300">*</span>
                        }
                        else
                        {
                            @k.AllowedIps
                        }
                    </td>
                    <td class="px-4 py-3 text-xs text-gray-500">
                        @if (k.ExpiresAt.HasValue)
                        {
                            @k.ExpiresAt.Value.ToLocalTime().ToString("dd/MM/yy")
                        }
                        else
                        {
                            <span class="text-gray-300">ไม่มี</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-xs text-gray-400">
                        @(k.LastUsedAt.HasValue ? k.LastUsedAt.Value.ToLocalTime().ToString("dd/MM/yy HH:mm") : "—")
                    </td>
                    <td class="px-4 py-3">
                        @if (k.IsActive)
                        {
                            <span class="flex items-center gap-1 text-xs text-green-700">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> ใช้งานได้
                            </span>
                        }
                        else
                        {
                            <span class="flex items-center gap-1 text-xs text-red-600">
                                <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span> ยกเลิกแล้ว
                            </span>
                            @if (!string.IsNullOrEmpty(k.RevokedReason))
                            {
                                <div class="text-[10px] text-gray-400 mt-0.5 max-w-[100px] truncate" title="@k.RevokedReason">
                                    @k.RevokedReason
                                </div>
                            }
                        }
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                        <a asp-page="/Admin/ApiKeyUsage" asp-route-keyId="@k.Id"
                           class="text-xs text-srt-navy hover:underline font-medium">Usage</a>
                        @if (k.IsActive)
                        {
                            <details class="relative">
                                <summary class="text-xs text-red-600 hover:text-red-800 cursor-pointer list-none font-medium">ยกเลิก</summary>
                                <div class="absolute right-0 top-6 z-10 bg-white border border-gray-200 rounded-xl shadow-lg p-4 w-64">
                                    <form method="post" asp-page-handler="Revoke">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="RevokeId" value="@k.Id" />
                                        <p class="text-xs font-medium text-gray-700 mb-2">ยกเลิก "@k.Name"</p>
                                        <textarea name="RevokeReason" required rows="2" placeholder="ระบุเหตุผล..."
                                                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm mb-2 focus:outline-none focus:border-red-400 resize-none"></textarea>
                                        <button type="submit"
                                                onclick="return confirm('ยืนยันยกเลิก API Key นี้?')"
                                                class="w-full bg-red-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium hover:bg-red-700 transition">
                                            ยืนยันยกเลิก
                                        </button>
                                    </form>
                                </div>
                            </details>
                        }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ══ Create New API Key ══ -->
<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
    <h2 class="text-sm font-semibold text-gray-900 mb-4">สร้าง API Key ใหม่</h2>
    <form method="post" asp-page-handler="Create" class="space-y-4">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="lg:col-span-2">
                <label class="block text-xs font-medium text-gray-600 mb-1">ชื่อ API Key <span class="text-red-500">*</span></label>
                <input name="NewName" required placeholder="เช่น ระบบ eDOC ฝ่ายพาณิชย์"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">ประเภท</label>
                <select name="NewKeyType"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy">
                    <option value="External">External</option>
                    <option value="Internal">Internal</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Rate Limit (req/min)</label>
                <input name="NewRateLimit" type="number" value="60" min="1" max="3600"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy" />
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">IP Whitelist <span class="text-gray-400">(เว้นว่างไว้ = ทุก IP)</span></label>
                <input name="NewAllowedIps" placeholder="เช่น 192.168.1.0/24, 10.0.0.1"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:border-srt-navy" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">วันหมดอายุ <span class="text-gray-400">(ไม่ระบุ = ไม่มีวันหมดอายุ)</span></label>
                <input name="NewExpiresAt" type="date"
                       min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                       data-datepicker
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-srt-navy" />
            </div>
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-600 mb-2">Scopes <span class="text-red-500">*</span></label>
            <div class="flex flex-wrap gap-3">
                @foreach (var scope in ApiKeysModel.AvailableScopes)
                {
                    <label class="flex items-center gap-2 cursor-pointer select-none
                                  border border-gray-200 rounded-lg px-3 py-2 hover:border-srt-navy/40 transition">
                        <input type="checkbox" name="NewScopes" value="@scope"
                               class="w-4 h-4 rounded border-gray-300 text-srt-navy focus:ring-srt-navy" />
                        <span class="font-mono text-xs text-gray-700">@scope</span>
                    </label>
                }
            </div>
        </div>

        <div class="flex justify-end pt-2 border-t border-gray-100">
            <button type="submit"
                    class="bg-srt-navy text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-srt-navy-dark transition">
                สร้าง API Key
            </button>
        </div>
    </form>
</div>
