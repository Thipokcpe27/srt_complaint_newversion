@page
@model SRT.Complaint.Pages.Admin.ReportsModel
@{
    ViewData["Title"] = "รายงาน";
}

<!-- ══ Summary Cards ══ -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">ทั้งหมด</p>
        <p class="text-3xl font-bold text-srt-navy mt-1">@Model.TotalAll.ToString("N0")</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">ค้างอยู่</p>
        <p class="text-3xl font-bold text-amber-600 mt-1">@Model.TotalOpen.ToString("N0")</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">ปิดแล้ว</p>
        <p class="text-3xl font-bold text-green-600 mt-1">@Model.TotalClosed.ToString("N0")</p>
    </div>
    <div class="bg-white rounded-xl border @(Model.TotalBreached > 0 ? "border-red-300 bg-red-50" : "border-gray-200") p-4 shadow-sm">
        <p class="text-xs font-medium @(Model.TotalBreached > 0 ? "text-red-600" : "text-gray-500") uppercase tracking-wide">เกิน SLA (ค้างอยู่)</p>
        <p class="text-3xl font-bold text-red-600 mt-1">@Model.TotalBreached.ToString("N0")</p>
    </div>
</div>

<!-- ══ Charts Row ══ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <!-- Monthly Trend -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold text-gray-900">จำนวนเรื่องรายเดือน (12 เดือนล่าสุด)</h2>
        </div>
        <canvas id="monthlyChart" height="120"></canvas>
    </div>

    <!-- By Category -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">เรื่องตามหมวดหมู่ (Top 10)</h2>
        <canvas id="categoryChart" height="120"></canvas>
    </div>

</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <!-- By Status -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">สัดส่วนตามสถานะ</h2>
        <div class="flex items-center gap-6">
            <div class="w-40 h-40 shrink-0">
                <canvas id="statusChart"></canvas>
            </div>
            <div class="space-y-1.5">
                @{
                    var statusColors = new Dictionary<string, string>
                    {
                        ["Pending"]     = "bg-amber-400",
                        ["InProgress"]  = "bg-blue-400",
                        ["WaitingInfo"] = "bg-purple-400",
                        ["Forwarded"]   = "bg-indigo-400",
                        ["Resolved"]    = "bg-green-400",
                        ["Closed"]      = "bg-gray-400",
                        ["Rejected"]    = "bg-red-400",
                    };
                    var statusLabels = new Dictionary<string, string>
                    {
                        ["Pending"]     = "รอดำเนินการ",
                        ["InProgress"]  = "กำลังดำเนินการ",
                        ["WaitingInfo"] = "รอข้อมูลเพิ่มเติม",
                        ["Forwarded"]   = "ส่งต่อแผนก",
                        ["Resolved"]    = "แก้ไขแล้ว",
                        ["Closed"]      = "ปิดเรื่อง",
                        ["Rejected"]    = "ปฏิเสธ",
                    };
                }
                @foreach (var s in Model.ByStatusSeries)
                {
                    var colorClass = statusColors.GetValueOrDefault(s.Status, "bg-gray-300");
                    var label = statusLabels.GetValueOrDefault(s.Status, s.Status);
                    <div class="flex items-center gap-2 text-xs">
                        <span class="w-2.5 h-2.5 rounded-sm @colorClass shrink-0"></span>
                        <span class="text-gray-600">@label</span>
                        <span class="ml-auto font-medium text-gray-900">@s.Count</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Top Staff This Month -->
    <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">เรื่องที่ปิดเดือนนี้ (Top Staff)</h2>
        @if (!Model.TopStaff.Any())
        {
            <p class="text-sm text-gray-400 text-center py-6">ยังไม่มีข้อมูลเดือนนี้</p>
        }
        else
        {
            var maxClosed = Model.TopStaff.Max(s => s.ClosedThisMonth);
            <div class="space-y-3">
                @foreach (var staff in Model.TopStaff)
                {
                    var pct = maxClosed > 0 ? (int)(staff.ClosedThisMonth * 100.0 / maxClosed) : 0;
                    <div>
                        <div class="flex justify-between text-xs mb-1">
                            <span class="font-medium text-gray-800">@staff.FullName</span>
                            <span class="text-gray-500">@staff.ClosedThisMonth เรื่อง</span>
                        </div>
                        <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                            <div class="h-2 bg-srt-navy rounded-full transition-all" style="width:@pct%"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

<!-- ══ Export ══ -->
<div class="flex justify-end">
    <form method="post" asp-page-handler="Export">
        @Html.AntiForgeryToken()
        <button type="submit"
                class="flex items-center gap-2 bg-green-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium
                       hover:bg-green-700 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Export Excel (ล่าสุด 5,000 เรื่อง)
        </button>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <script>
    (function () {
        const navy = '#1A4A9A', navyLight = '#3B6CC7';

        // Monthly trend
        new Chart(document.getElementById('monthlyChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyLabels)),
                datasets: [{
                    label: 'จำนวนเรื่อง',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyData)),
                    borderColor: navy,
                    backgroundColor: 'rgba(26,74,154,0.08)',
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: navy,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: '#F3F4F6' } },
                    x: { grid: { display: false } }
                }
            }
        });

        // By category
        new Chart(document.getElementById('categoryChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ByCategorySeries.Select(x => x.Name).ToList())),
                datasets: [{
                    label: 'จำนวนเรื่อง',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ByCategorySeries.Select(x => x.Count).ToList())),
                    backgroundColor: navyLight,
                    borderRadius: 4,
                    borderSkipped: false,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    x: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: '#F3F4F6' } },
                    y: { grid: { display: false } }
                }
            }
        });

        // By status doughnut
        const statusColors = ['#F59E0B','#3B82F6','#A855F7','#6366F1','#22C55E','#9CA3AF','#EF4444'];
        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ByStatusSeries.Select(x => x.Status).ToList())),
                datasets: [{
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ByStatusSeries.Select(x => x.Count).ToList())),
                    backgroundColor: statusColors,
                    borderWidth: 2,
                    borderColor: '#fff',
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                cutout: '65%'
            }
        });
    })();
    </script>
}
