@page
@model SRT.Complaint.Pages.Public.SubmitModel
@{
    ViewData["Title"] = "ยื่นเรื่องร้องเรียน";
    Layout = "_Layout";
}

<div class="max-w-3xl mx-auto">

    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">ยื่นเรื่องร้องเรียนทั่วไป</h1>
        <p class="text-gray-500 mt-1 text-sm">กรุณากรอกข้อมูลให้ครบถ้วน เจ้าหน้าที่จะดำเนินการและแจ้งผลทาง SMS / อีเมลที่ท่านระบุ</p>
    </div>

    <form method="post" enctype="multipart/form-data" id="complaint-form" novalidate>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 [&:empty]:hidden">
        </div>

        <!-- Section 1: ข้อมูลผู้ร้องเรียน -->
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="font-semibold text-gray-800 flex items-center gap-2">
                    <span class="w-6 h-6 bg-srt-navy text-white text-xs rounded-full flex items-center justify-center shrink-0">1</span>
                    ข้อมูลผู้ร้องเรียน
                </h2>
            </div>
            <div class="card-body">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                    <!-- ชื่อ-นามสกุล -->
                    <div class="sm:col-span-2">
                        <label asp-for="Input.ReporterName"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            ชื่อ-นามสกุล <span class="text-red-500" aria-hidden="true">*</span>
                        </label>
                        <input asp-for="Input.ReporterName"
                               type="text"
                               autocomplete="name"
                               placeholder="ชื่อ นามสกุล (ไม่ต้องใส่คำนำหน้า)"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                      focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                      transition-colors aria-[invalid]:border-red-400" />
                        <span asp-validation-for="Input.ReporterName"
                              class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <!-- เบอร์โทรศัพท์ -->
                    <div>
                        <label asp-for="Input.ReporterPhone"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            เบอร์โทรศัพท์ <span class="text-red-500" aria-hidden="true">*</span>
                        </label>
                        <input asp-for="Input.ReporterPhone"
                               type="tel"
                               inputmode="numeric"
                               autocomplete="tel"
                               placeholder="0812345678"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                      focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                      transition-colors" />
                        <span asp-validation-for="Input.ReporterPhone"
                              class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <!-- อีเมล -->
                    <div>
                        <label asp-for="Input.ReporterEmail"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            อีเมล
                            <span class="text-gray-400 font-normal">(ถ้ามี)</span>
                        </label>
                        <input asp-for="Input.ReporterEmail"
                               type="email"
                               autocomplete="email"
                               placeholder="example@email.com"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                      focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                      transition-colors" />
                        <span asp-validation-for="Input.ReporterEmail"
                              class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                </div>
            </div>
        </div>

        <!-- Section 2: รายละเอียดเรื่องร้องเรียน -->
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="font-semibold text-gray-800 flex items-center gap-2">
                    <span class="w-6 h-6 bg-srt-navy text-white text-xs rounded-full flex items-center justify-center shrink-0">2</span>
                    รายละเอียดเรื่องร้องเรียน
                </h2>
            </div>
            <div class="card-body">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                    <!-- ประเภทเรื่อง -->
                    <div>
                        <label asp-for="Input.CategoryId"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            ประเภทเรื่อง <span class="text-red-500" aria-hidden="true">*</span>
                        </label>
                        <select asp-for="Input.CategoryId"
                                asp-items="Model.CategoryOptions"
                                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                       focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                       transition-colors">
                            <option value="">— เลือกประเภทเรื่อง —</option>
                        </select>
                        <span asp-validation-for="Input.CategoryId"
                              class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <!-- สถานี / จุดที่เกิดเหตุ -->
                    <div>
                        <label asp-for="Input.SubjectStation"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            สถานี / จุดที่เกิดเหตุ
                            <span class="text-gray-400 font-normal">(ถ้ามี)</span>
                        </label>
                        <input asp-for="Input.SubjectStation"
                               type="text"
                               placeholder="เช่น สถานีกรุงเทพ, ขบวน 7"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                      focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                      transition-colors" />
                        <span asp-validation-for="Input.SubjectStation"
                              class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <!-- วันที่เกิดเหตุ -->
                    <div class="sm:col-span-2 sm:max-w-xs">
                        <label asp-for="Input.IncidentDate"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            วันที่เกิดเหตุ
                            <span class="text-gray-400 font-normal">(ถ้าทราบ)</span>
                        </label>
                        <input asp-for="Input.IncidentDate"
                               type="date"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm
                                      focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                      transition-colors" />
                        <span asp-validation-for="Input.IncidentDate"
                              class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <!-- รายละเอียด -->
                    <div class="sm:col-span-2">
                        <label asp-for="Input.Description"
                               class="block text-sm font-medium text-gray-700 mb-1">
                            รายละเอียดเรื่องร้องเรียน <span class="text-red-500" aria-hidden="true">*</span>
                        </label>
                        <textarea asp-for="Input.Description"
                                  rows="6"
                                  maxlength="4000"
                                  placeholder="อธิบายรายละเอียดเรื่องที่ต้องการร้องเรียน เช่น เกิดอะไรขึ้น เมื่อใด ใครเกี่ยวข้อง ผลกระทบที่ได้รับ..."
                                  oninput="document.getElementById('desc-count').textContent = this.value.length"
                                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm resize-none
                                         focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                         transition-colors"></textarea>
                        <div class="flex justify-between mt-1">
                            <span asp-validation-for="Input.Description"
                                  class="text-red-600 text-xs block"></span>
                            <span class="text-xs text-gray-400 ml-auto">
                                <span id="desc-count">0</span>/4,000
                            </span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Section 3: ไฟล์แนบ -->
        <div class="card mb-8">
            <div class="card-header">
                <h2 class="font-semibold text-gray-800 flex items-center gap-2">
                    <span class="w-6 h-6 bg-srt-navy text-white text-xs rounded-full flex items-center justify-center shrink-0">3</span>
                    ไฟล์แนบ
                    <span class="text-gray-400 font-normal text-sm ml-1">(ไม่บังคับ)</span>
                </h2>
            </div>
            <div class="card-body">
                <div class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center
                            hover:border-srt-navy/50 transition-colors"
                     id="drop-zone">
                    <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                              d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                    </svg>
                    <p class="text-sm text-gray-500 mb-1">ลากไฟล์มาวางที่นี่ หรือ</p>
                    <label class="cursor-pointer inline-block mt-1">
                        <span class="text-srt-navy text-sm font-medium hover:underline">คลิกเพื่อเลือกไฟล์</span>
                        <input type="file"
                               name="Input.Attachments"
                               multiple
                               accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                               class="sr-only"
                               id="file-input"
                               onchange="updateFileList(this.files)" />
                    </label>
                    <p class="text-xs text-gray-400 mt-2">JPG, PNG, PDF, DOC, DOCX · สูงสุด 5 ไฟล์ · ไม่เกิน 10 MB ต่อไฟล์</p>
                </div>

                <ul id="file-list" class="mt-3 space-y-1.5 hidden" aria-label="รายการไฟล์ที่เลือก"></ul>
                <span asp-validation-for="Input.Attachments"
                      class="text-red-600 text-xs mt-1 block"></span>
            </div>
        </div>

        <!-- Privacy Notice -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6 text-xs text-blue-700 leading-relaxed">
            <strong>ข้อมูลส่วนบุคคล:</strong> ข้อมูลที่ท่านให้ไว้จะถูกใช้เพื่อดำเนินการตามเรื่องร้องเรียนเท่านั้น
            และปกป้องตามนโยบายความเป็นส่วนตัวของ รฟท.
            หากต้องการสอบถามเพิ่มเติม ติดต่อ ☎ 1690
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-4">
            <button type="submit"
                    id="submit-btn"
                    class="btn-primary px-8 py-2.5 flex items-center gap-2">
                <span id="submit-spinner"
                      class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"
                      aria-hidden="true"></span>
                ยื่นเรื่องร้องเรียน
            </button>
            <a asp-page="/Public/Index"
               class="text-sm text-gray-500 hover:text-gray-700 transition">ยกเลิก</a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Character counter init
        (function () {
            const ta = document.querySelector('textarea[name="Input.Description"]');
            if (ta) document.getElementById('desc-count').textContent = ta.value.length;
        })();

        // File list display
        function updateFileList(files) {
            const list = document.getElementById('file-list');
            list.innerHTML = '';
            if (!files || files.length === 0) { list.classList.add('hidden'); return; }
            list.classList.remove('hidden');
            Array.from(files).forEach(f => {
                const li = document.createElement('li');
                li.className = 'flex items-center gap-2 text-xs text-gray-600 bg-gray-50 rounded-lg px-3 py-2';
                li.innerHTML = `<svg class="w-4 h-4 text-srt-navy shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg><span class="truncate">${f.name}</span><span class="ml-auto shrink-0 text-gray-400">${(f.size / 1024 / 1024).toFixed(1)} MB</span>`;
                list.appendChild(li);
            });
        }

        // Drag-and-drop
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-srt-navy', 'bg-blue-50'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-srt-navy', 'bg-blue-50'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('border-srt-navy', 'bg-blue-50');
            const dt = new DataTransfer();
            Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
            fileInput.files = dt.files;
            updateFileList(fileInput.files);
        });

        // Loading spinner on submit
        document.getElementById('complaint-form').addEventListener('submit', function () {
            const btn = document.getElementById('submit-btn');
            const spinner = document.getElementById('submit-spinner');
            btn.disabled = true;
            spinner.classList.remove('hidden');
        });
    </script>
}
