@page
@model SRT.Complaint.Pages.Public.SubmitModel
@{
    ViewData["Title"] = "ยื่นเรื่องร้องเรียน";
    Layout = "_Layout";
}

<partial name="_TermsModal" model="Model.Terms" />

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
<div class="max-w-3xl mx-auto">

    <!-- Page Header -->
    <div class="mb-8">
        <nav class="flex items-center gap-2 text-xs text-gray-400 mb-4" aria-label="breadcrumb">
            <a href="/" class="hover:text-srt-navy transition">หน้าแรก</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <span class="text-gray-600 font-medium">ยื่นเรื่องร้องเรียน</span>
        </nav>
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">ยื่นเรื่องร้องเรียนทั่วไป</h1>
        <p class="text-gray-500 mt-2">กรุณากรอกข้อมูลให้ครบถ้วน เจ้าหน้าที่จะแจ้งผลทาง SMS/อีเมลภายใน SLA ที่กำหนด</p>
    </div>

<div id="form-content-wrapper" class="@(Model.Terms?.IsActive == true ? "hidden" : "")">
    <form method="post" enctype="multipart/form-data" id="complaint-form" novalidate>
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="alert-error mb-6 [&:empty]:hidden">
        </div>

        <!-- Section 1: ข้อมูลผู้ร้องเรียน -->
        <div class="card mb-5">
            <div class="card-header">
                <h2 class="font-bold text-gray-900 flex items-center gap-3 text-sm">
                    <span class="w-7 h-7 bg-srt-navy text-white text-xs font-bold rounded-xl
                                 flex items-center justify-center shrink-0">1</span>
                    ข้อมูลผู้ร้องเรียน
                </h2>
            </div>
            <div class="card-body">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                    <div class="sm:col-span-2">
                        <label asp-for="Input.ReporterName" class="form-label">
                            ชื่อ-นามสกุล <span class="text-red-500" aria-hidden="true">*</span>
                            <span class="sr-only">(จำเป็น)</span>
                        </label>
                        <input asp-for="Input.ReporterName" type="text" autocomplete="name"
                               placeholder="ชื่อ นามสกุล (ไม่ต้องใส่คำนำหน้า)"
                               aria-required="true"
                               aria-describedby="Input_ReporterName-error"
                               class="form-input" />
                        <span id="Input_ReporterName-error" asp-validation-for="Input.ReporterName" class="form-error block" role="alert"></span>
                    </div>

                    <div>
                        <label asp-for="Input.ReporterPhone" class="form-label">
                            เบอร์โทรศัพท์ <span class="text-red-500" aria-hidden="true">*</span>
                            <span class="sr-only">(จำเป็น)</span>
                        </label>
                        <input asp-for="Input.ReporterPhone" type="tel" inputmode="numeric"
                               autocomplete="tel" placeholder="081-234-5678"
                               data-mask="phone" maxlength="12"
                               aria-required="true"
                               aria-describedby="Input_ReporterPhone-error"
                               class="form-input" />
                        <span id="Input_ReporterPhone-error" asp-validation-for="Input.ReporterPhone" class="form-error block" role="alert"></span>
                    </div>

                    <div>
                        <label asp-for="Input.ReporterEmail" class="form-label">
                            อีเมล <span class="text-gray-400 font-normal">(ถ้ามี)</span>
                        </label>
                        <input asp-for="Input.ReporterEmail" type="email" autocomplete="email"
                               placeholder="example@email.com"
                               data-block="thai"
                               class="form-input" />
                        <span asp-validation-for="Input.ReporterEmail" class="form-error block"></span>
                    </div>

                    <div class="sm:col-span-2 sm:max-w-xs">
                        <label asp-for="Input.ReporterIdCard" class="form-label">
                            เลขบัตรประชาชน <span class="text-gray-400 font-normal">(ถ้ามี)</span>
                        </label>
                        <input asp-for="Input.ReporterIdCard" type="text" inputmode="numeric"
                               placeholder="1-2345-67890-12-3"
                               data-mask="id-card" maxlength="17"
                               class="form-input tracking-widest" />
                        <span asp-validation-for="Input.ReporterIdCard" class="form-error block"></span>
                    </div>

                </div>
            </div>
        </div>

        <!-- Section 2: รายละเอียดเรื่องร้องเรียน -->
        <div class="card mb-5">
            <div class="card-header">
                <h2 class="font-bold text-gray-900 flex items-center gap-3 text-sm">
                    <span class="w-7 h-7 bg-srt-navy text-white text-xs font-bold rounded-xl
                                 flex items-center justify-center shrink-0">2</span>
                    รายละเอียดเรื่องร้องเรียน
                </h2>
            </div>
            <div class="card-body">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                    <div>
                        <label asp-for="Input.CategoryId" class="form-label">
                            ประเภทเรื่อง <span class="text-red-500" aria-hidden="true">*</span>
                            <span class="sr-only">(จำเป็น)</span>
                        </label>
                        <select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions"
                                class="form-select" id="category-select"
                                aria-required="true"
                                aria-describedby="Input_CategoryId-error">
                            <option value="">— เลือกประเภทเรื่อง —</option>
                        </select>
                        <span id="Input_CategoryId-error" asp-validation-for="Input.CategoryId" class="form-error block" role="alert"></span>
                    </div>

                    <div id="subcategory-wrap" class="hidden">
                        <label asp-for="Input.SubCategoryId" class="form-label">
                            หัวข้อย่อย <span class="text-gray-400 font-normal">(ถ้ามี)</span>
                        </label>
                        <select asp-for="Input.SubCategoryId" class="form-select" id="subcategory-select">
                            <option value="">— เลือกหัวข้อย่อย —</option>
                        </select>
                    </div>

                    <div>
                        <label asp-for="Input.SubjectStation" class="form-label">
                            สถานี / จุดที่เกิดเหตุ <span class="text-gray-400 font-normal">(ถ้ามี)</span>
                        </label>
                        <input asp-for="Input.SubjectStation" type="text"
                               placeholder="เช่น สถานีกรุงเทพ, ขบวน 7"
                               class="form-input" />
                        <span asp-validation-for="Input.SubjectStation" class="form-error block"></span>
                    </div>

                    <div class="sm:col-span-2 sm:max-w-xs">
                        <label asp-for="Input.IncidentDate" class="form-label">
                            วันที่เกิดเหตุ <span class="text-gray-400 font-normal">(ถ้าทราบ)</span>
                        </label>
                        <input asp-for="Input.IncidentDate" type="date"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")"
                               data-datepicker
                               class="form-input" />
                        <span asp-validation-for="Input.IncidentDate" class="form-error block"></span>
                    </div>

                    <div class="sm:col-span-2">
                        <label asp-for="Input.Description" class="form-label">
                            รายละเอียดเรื่องร้องเรียน <span class="text-red-500" aria-hidden="true">*</span>
                            <span class="sr-only">(จำเป็น)</span>
                        </label>
                        <textarea asp-for="Input.Description" rows="6" maxlength="4000"
                                  placeholder="อธิบายรายละเอียดเรื่องที่ต้องการร้องเรียน เช่น เกิดอะไรขึ้น เมื่อใด ใครเกี่ยวข้อง ผลกระทบที่ได้รับ..."
                                  aria-required="true"
                                  aria-describedby="Input_Description-error desc-count-hint"
                                  oninput="document.getElementById('desc-count').textContent = this.value.length"
                                  class="form-textarea w-full"></textarea>
                        <div class="flex justify-between mt-1.5">
                            <span id="Input_Description-error" asp-validation-for="Input.Description" class="form-error block" role="alert"></span>
                            <span id="desc-count-hint" class="text-xs text-gray-400 ml-auto" aria-live="polite">
                                <span id="desc-count">0</span>/4,000 ตัวอักษร
                            </span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Section 3: ไฟล์แนบ -->
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="font-bold text-gray-900 flex items-center gap-3 text-sm">
                    <span class="w-7 h-7 bg-srt-navy text-white text-xs font-bold rounded-xl
                                 flex items-center justify-center shrink-0">3</span>
                    ไฟล์แนบ
                    <span class="text-gray-400 font-normal">(ไม่บังคับ)</span>
                </h2>
            </div>
            <div class="card-body">
                <div class="border-2 border-dashed border-gray-200 rounded-2xl p-10 text-center
                            hover:border-srt-navy/40 hover:bg-srt-navy-50/30 transition-all duration-200
                            cursor-pointer group" id="drop-zone"
                     onclick="document.getElementById('file-input').click()">
                    <div class="w-12 h-12 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-3
                                group-hover:bg-srt-navy-50 transition-colors duration-200">
                        <svg class="w-6 h-6 text-gray-400 group-hover:text-srt-navy transition-colors duration-200"
                             fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                        </svg>
                    </div>
                    <p class="text-sm font-semibold text-gray-700 mb-1">ลากไฟล์มาวาง หรือคลิกเพื่อเลือก</p>
                    <p class="text-xs text-gray-400">JPG, PNG, PDF, DOC, DOCX · สูงสุด 5 ไฟล์ · ไม่เกิน 10 MB ต่อไฟล์</p>
                    <input type="file" name="Input.Attachments" multiple
                           accept=".jpg,.jpeg,.png,.pdf,.doc,.docx"
                           class="sr-only" id="file-input"
                           onchange="updateFileList(this.files)" />
                </div>

                <ul id="file-list" class="mt-3 space-y-2 hidden" aria-label="รายการไฟล์ที่เลือก"></ul>
                <span asp-validation-for="Input.Attachments" class="form-error block mt-2"></span>
            </div>
        </div>

        <!-- Privacy Notice -->
        <div class="bg-srt-navy-50 border border-srt-navy-100 rounded-2xl p-4 mb-6 flex gap-3">
            <svg class="w-4 h-4 text-srt-navy shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <p class="text-xs text-srt-navy/80 leading-relaxed">
                <strong class="text-srt-navy">ข้อมูลส่วนบุคคล:</strong> ข้อมูลที่ท่านให้ไว้จะถูกใช้เพื่อดำเนินการตามเรื่องร้องเรียนเท่านั้น
                และปกป้องตามนโยบายความเป็นส่วนตัวของ รฟท. สอบถามเพิ่มเติม ☎ 1690
            </p>
        </div>

        <!-- Turnstile -->
        @if (!string.IsNullOrEmpty(Model.TurnstileSiteKey))
        {
            <div class="cf-turnstile mb-4"
                 data-sitekey="@Model.TurnstileSiteKey"
                 data-theme="light"
                 data-language="th">
            </div>
        }

        <!-- Actions -->
        <div class="flex items-center gap-4">
            <button type="submit" id="submit-btn" class="btn-primary btn-lg">
                <span id="submit-spinner"
                      class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"
                      aria-hidden="true"></span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
                ยื่นเรื่องร้องเรียน
            </button>
            <a asp-page="/Index" class="text-sm text-gray-400 hover:text-gray-600 transition font-medium">ยกเลิก</a>
        </div>

    </form>
</div>
</div>
</div>

@section Scripts {
    @if (!string.IsNullOrEmpty(Model.TurnstileSiteKey))
    {
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    }
    <partial name="_ValidationScriptsPartial" />
    <script>
        $.validator.setDefaults({
            normalizer: function (value) {
                if ($(this).data('mask')) return value.replace(/\D/g, '');
                return value;
            }
        });
        /* ─── Input masks ─────────────────────────────────────────── */
        function applyPhoneMask(el) {
            const raw = el.value.replace(/\D/g, '');
            const d = raw.slice(0, 10);
            if (d.length <= 2) { el.value = d; return; }
            // Bangkok landline starts with 02 → 0X-XXX-XXXX (9 digits max)
            if (d[1] === '2') {
                const s = d.slice(0, 9);
                if (s.length <= 5) el.value = s.slice(0, 2) + '-' + s.slice(2);
                else el.value = s.slice(0, 2) + '-' + s.slice(2, 5) + '-' + s.slice(5);
            } else {
                // Mobile / regional: 0XX-XXX-XXXX (10 digits)
                if (d.length <= 3) el.value = d;
                else if (d.length <= 6) el.value = d.slice(0, 3) + '-' + d.slice(3);
                else el.value = d.slice(0, 3) + '-' + d.slice(3, 6) + '-' + d.slice(6);
            }
        }

        function applyIdCardMask(el) {
            const d = el.value.replace(/\D/g, '').slice(0, 13);
            let f = d.slice(0, 1);
            if (d.length > 1)  f += '-' + d.slice(1, 5);
            if (d.length > 5)  f += '-' + d.slice(5, 10);
            if (d.length > 10) f += '-' + d.slice(10, 12);
            if (d.length > 12) f += '-' + d.slice(12, 13);
            el.value = f;
        }

        function initMasks(form) {
            form.querySelectorAll('[data-mask="phone"]').forEach(function (el) {
                el.addEventListener('input', function () { applyPhoneMask(this); });
                if (el.value) applyPhoneMask(el);
            });
            form.querySelectorAll('[data-mask="id-card"]').forEach(function (el) {
                el.addEventListener('input', function () { applyIdCardMask(this); });
                if (el.value) applyIdCardMask(el);
            });
            // Strip dashes before jQuery Validate fires (capture phase → before bubble)
            form.addEventListener('submit', function () {
                form.querySelectorAll('[data-mask="phone"]').forEach(function (el) {
                    el.value = el.value.replace(/\D/g, '');
                });
                form.querySelectorAll('[data-mask="id-card"]').forEach(function (el) {
                    el.value = el.value.replace(/\D/g, '');
                });
            }, true);
        }

        (function () {
            const form = document.getElementById('complaint-form');
            initMasks(form);
        })();
        /* ────────────────────────────────────────────────────────── */

        (function () {
            const ta = document.querySelector('textarea[name="Input.Description"]');
            if (ta) document.getElementById('desc-count').textContent = ta.value.length;
        })();

        (function () {
            const subCats = @Html.Raw(Model.SubCategoriesJson);
            const catSel = document.getElementById('category-select');
            const subWrap = document.getElementById('subcategory-wrap');
            const subSel = document.getElementById('subcategory-select');
            const selectedSubId = '@(Model.Input.SubCategoryId)';

            function updateSubCats() {
                const catId = catSel.value;
                const items = subCats[catId] || [];
                subSel.innerHTML = '<option value="">— เลือกหัวข้อย่อย —</option>';
                if (items.length === 0) {
                    subWrap.classList.add('hidden');
                    return;
                }
                items.forEach(function (s) {
                    const opt = document.createElement('option');
                    opt.value = s.id;
                    opt.textContent = s.name;
                    if (String(s.id) === selectedSubId) opt.selected = true;
                    subSel.appendChild(opt);
                });
                subWrap.classList.remove('hidden');
            }

            catSel.addEventListener('change', updateSubCats);
            if (catSel.value) updateSubCats();
        })();

        function updateFileList(files) {
            const list = document.getElementById('file-list');
            list.innerHTML = '';
            if (!files || files.length === 0) { list.classList.add('hidden'); return; }
            list.classList.remove('hidden');
            Array.from(files).forEach(f => {
                const li = document.createElement('li');
                li.className = 'flex items-center gap-3 text-xs text-gray-700 bg-gray-50 border border-gray-100 rounded-xl px-4 py-2.5';
                const iconSvg = `<svg class="w-4 h-4 text-srt-navy shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>`;
                li.innerHTML = `${iconSvg}<span class="truncate font-medium">${f.name}</span><span class="ml-auto shrink-0 text-gray-400">${(f.size/1024/1024).toFixed(1)} MB</span>`;
                list.appendChild(li);
            });
        }

        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        dropZone.addEventListener('dragover', e => {
            e.preventDefault();
            dropZone.classList.add('border-srt-navy', 'bg-srt-navy-50');
        });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-srt-navy', 'bg-srt-navy-50'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('border-srt-navy', 'bg-srt-navy-50');
            const dt = new DataTransfer();
            Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
            fileInput.files = dt.files;
            updateFileList(fileInput.files);
        });

        document.getElementById('complaint-form').addEventListener('submit', function () {
            const btn = document.getElementById('submit-btn');
            const spinner = document.getElementById('submit-spinner');
            btn.disabled = true;
            spinner.classList.remove('hidden');
            btn.querySelector('svg:not(.animate-spin)')?.classList.add('hidden');
        });
    </script>
}
