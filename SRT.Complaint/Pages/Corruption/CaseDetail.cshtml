@page "{id:int}"
@model SRT.Complaint.Pages.Corruption.CaseDetailModel
@using System.Security.Claims
@{
    ViewData["Title"] = $"ทุจริต {Model.Report.ReferenceNumber}";
    var r = Model.Report;
    var now = DateTime.UtcNow;
    var isClosed     = r.Status is "Closed" or "Rejected";
    var slaBreached  = r.SlaBreached || (r.SlaDeadline.HasValue && r.SlaDeadline < now);
    var currentStaff = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
    var isAssignedToMe = r.AssignedToId == currentStaff;

    string StatusColor(string s) => s switch
    {
        "Pending"     => "bg-amber-100 text-amber-800 border-amber-200",
        "InProgress"  => "bg-blue-100 text-blue-800 border-blue-200",
        "UnderReview" => "bg-purple-100 text-purple-800 border-purple-200",
        "Closed"      => "bg-gray-200 text-gray-700 border-gray-300",
        "Rejected"    => "bg-red-100 text-red-800 border-red-200",
        _             => "bg-gray-100 text-gray-700 border-gray-200"
    };
}

<!-- ══ Security Banner ══ -->
<div class="flex items-center gap-2 bg-amber-50 border border-amber-200 rounded-xl px-4 py-2.5 mb-4 text-xs text-amber-800">
    <svg class="w-4 h-4 shrink-0 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
    </svg>
    <span>
        <strong>ข้อมูลลับ</strong> — การถอดรหัสข้อมูลผู้แจ้งทุกครั้งถูกบันทึกใน Audit Log
        | ห้ามเผยแพร่ข้อมูลผู้แจ้งโดยไม่ได้รับอนุญาต
    </span>
</div>

<!-- ══ Page Header ══ -->
<div class="flex items-center justify-between mb-5">
    <div class="flex items-center gap-3">
        <a asp-page="/Corruption/Queue" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
        </a>
        <h1 class="text-base font-semibold text-gray-900 font-mono">@r.ReferenceNumber</h1>
        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border @StatusColor(r.Status)">
            @CaseDetailModel.StatusLabel(r.Status)
        </span>
        @if (slaBreached)
        {
            <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-600 text-white">⚠ เกิน SLA</span>
        }
    </div>
    <div class="flex items-center gap-3">
        <span class="text-xs text-gray-400">
            รับเมื่อ @r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
        </span>
        <form method="post" asp-page-handler="DownloadPdf" asp-route-id="@r.Id">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="inline-flex items-center gap-1.5 text-xs text-amber-700 border border-amber-300
                           px-3 py-1.5 rounded-lg hover:bg-amber-500 hover:text-white hover:border-amber-500 transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                PDF
            </button>
        </form>
    </div>
</div>

<!-- ══ Two-column Layout ══ -->
<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ── Left: Report Details + Timeline ── -->
    <div class="xl:col-span-2 space-y-5">

        <!-- ① Reporter Info (Masked / Decrypted) -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5" id="reporter-section">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
                    <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    ข้อมูลผู้แจ้ง
                </h2>
                @if (Model.DecryptedInfo == null)
                {
                    <span class="px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">
                        🔒 ปิดบัง
                    </span>
                }
                else
                {
                    <span class="px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">
                        🔓 ถอดรหัสแล้ว — จะหายเมื่อโหลดหน้าใหม่
                    </span>
                }
            </div>

            @if (Model.DecryptedInfo != null)
            {
                <!-- ─ Decrypted (one-time display) ─ -->
                <div class="bg-amber-50 border border-amber-300 rounded-xl p-4 mb-3">
                    <p class="text-xs font-semibold text-amber-800 mb-3 flex items-center gap-1.5">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        ข้อมูลจริง — จะไม่แสดงอีกเมื่อโหลดหน้าใหม่ และถูกบันทึกใน Audit Log แล้ว
                    </p>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
                        <div>
                            <dt class="text-xs text-amber-700 font-medium">ชื่อ-นามสกุล</dt>
                            <dd class="text-gray-900 mt-0.5 font-medium">@Model.DecryptedInfo.Name</dd>
                        </div>
                        <div>
                            <dt class="text-xs text-amber-700 font-medium">เบอร์โทรศัพท์</dt>
                            <dd class="text-gray-900 mt-0.5 font-mono">@Model.DecryptedInfo.Phone</dd>
                        </div>
                        @if (Model.DecryptedInfo.Email != null)
                        {
                            <div>
                                <dt class="text-xs text-amber-700 font-medium">อีเมล</dt>
                                <dd class="text-gray-900 mt-0.5">@Model.DecryptedInfo.Email</dd>
                            </div>
                        }
                        <div>
                            <dt class="text-xs text-amber-700 font-medium">เลขบัตรประชาชน</dt>
                            <dd class="text-gray-900 mt-0.5 font-mono tracking-wider">@Model.DecryptedInfo.IdCard</dd>
                        </div>
                    </dl>
                </div>
            }
            else
            {
                <!-- ─ Masked info ─ -->
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm mb-4">
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">ชื่อ-นามสกุล (ปิดบัง)</dt>
                        <dd class="font-mono text-gray-500 mt-0.5 tracking-wider">@r.ReporterNameMasked</dd>
                    </div>
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">เบอร์โทรศัพท์ (ปิดบัง)</dt>
                        <dd class="font-mono text-gray-500 mt-0.5 tracking-wider">@r.ReporterPhoneMasked</dd>
                    </div>
                    @if (r.ReporterEmailMasked != null)
                    {
                        <div>
                            <dt class="text-xs text-gray-500 font-medium">อีเมล (ปิดบัง)</dt>
                            <dd class="font-mono text-gray-500 mt-0.5">@r.ReporterEmailMasked</dd>
                        </div>
                    }
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">เลขบัตรประชาชน</dt>
                        <dd class="font-mono text-gray-500 mt-0.5">x-xxxx-xxxxx-xx-x</dd>
                    </div>
                </dl>

                <!-- Decrypt form -->
                @if (!isClosed)
                {
                    <details class="border border-amber-200 rounded-xl overflow-hidden">
                        <summary class="flex items-center gap-2 px-4 py-2.5 bg-amber-50 cursor-pointer
                                        text-xs font-semibold text-amber-800 hover:bg-amber-100 transition list-none">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
                            </svg>
                            ขอดูข้อมูลผู้แจ้ง (ต้องระบุเหตุผล)
                        </summary>
                        <div class="px-4 py-3 bg-amber-50/50">
                            <p class="text-xs text-amber-700 mb-2">
                                การขอดูข้อมูลจะถูกบันทึกใน <strong>Audit Log</strong> ทันที พร้อม IP Address และชื่อผู้ขอ
                            </p>
                            <form method="post" asp-page-handler="Decrypt" asp-route-id="@r.Id">
                                @Html.AntiForgeryToken()
                                <textarea name="DecryptReason" rows="2" required
                                          placeholder="ระบุเหตุผลในการขอดูข้อมูล (เช่น: ติดต่อผู้แจ้งเพื่อยืนยันข้อมูลเพิ่มเติม)..."
                                          class="w-full border border-amber-300 rounded-lg px-3 py-2 text-sm mb-2
                                                 focus:outline-none focus:border-amber-500 focus:ring-2 focus:ring-amber-200
                                                 resize-none bg-white"></textarea>
                                <button type="submit"
                                        onclick="return confirm('การขอดูข้อมูลจะถูกบันทึกใน Audit Log ยืนยันหรือไม่?')"
                                        class="bg-amber-600 text-white text-xs px-4 py-2 rounded-lg
                                               hover:bg-amber-700 transition font-semibold">
                                    🔓 ยืนยันขอดูข้อมูล
                                </button>
                            </form>
                        </div>
                    </details>
                }
            }
        </div>

        <!-- ② Subject / Accusation Info -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
            <h2 class="text-sm font-semibold text-gray-900 mb-4">ข้อมูลผู้ถูกกล่าวหา / เรื่องที่แจ้ง</h2>
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
                <div>
                    <dt class="text-xs text-gray-500 font-medium">ประเภทเรื่อง</dt>
                    <dd class="text-gray-900 mt-0.5">@r.SubjectType</dd>
                </div>
                @if (!string.IsNullOrEmpty(r.SubjectPersonName))
                {
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">ชื่อผู้ถูกกล่าวหา</dt>
                        <dd class="text-gray-900 mt-0.5 font-medium">@r.SubjectPersonName</dd>
                    </div>
                }
                @if (!string.IsNullOrEmpty(r.SubjectDepartment))
                {
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">หน่วยงาน / แผนก</dt>
                        <dd class="text-gray-900 mt-0.5">@r.SubjectDepartment</dd>
                    </div>
                }
                @if (r.IncidentDate.HasValue)
                {
                    <div>
                        <dt class="text-xs text-gray-500 font-medium">วันที่เกิดเหตุ</dt>
                        <dd class="text-gray-900 mt-0.5">@r.IncidentDate.Value.ToString("dd/MM/yyyy")</dd>
                    </div>
                }
                <div>
                    <dt class="text-xs text-gray-500 font-medium">SLA Deadline</dt>
                    <dd class="mt-0.5 @(slaBreached ? "text-red-600 font-medium" : "text-gray-900")">
                        @(r.SlaDeadline.HasValue ? r.SlaDeadline.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—")
                        @if (slaBreached) { <text> ⚠</text> }
                    </dd>
                </div>
                <div>
                    <dt class="text-xs text-gray-500 font-medium">ผู้รับผิดชอบ</dt>
                    <dd class="text-gray-900 mt-0.5">
                        @(r.AssignedToId.HasValue ? Model.StaffNames.GetValueOrDefault(r.AssignedToId.Value, "—") : "ยังไม่ได้รับมอบหมาย")
                    </dd>
                </div>
            </dl>

            <div class="mt-4 pt-4 border-t border-gray-100">
                <dt class="text-xs text-gray-500 font-medium mb-1.5">รายละเอียด</dt>
                <dd class="text-gray-800 text-sm leading-relaxed bg-gray-50 rounded-xl p-3 whitespace-pre-wrap">@r.Description</dd>
            </div>
        </div>

        <!-- ③ Investigation Log Timeline -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
            <h2 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
                <svg class="w-4 h-4 text-srt-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                บันทึกการสืบสวน
            </h2>

            @if (!r.InvestigationLogs.Any())
            {
                <p class="text-sm text-gray-400 text-center py-6">ยังไม่มีบันทึกการสืบสวน</p>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var log in r.InvestigationLogs.OrderByDescending(l => l.CreatedAt))
                    {
                        var authorName = Model.StaffNames.GetValueOrDefault(log.AuthorId, $"Staff #{log.AuthorId}");
                        <div class="flex gap-3">
                            <div class="w-8 h-8 rounded-full bg-srt-navy/10 flex items-center justify-center
                                        text-xs font-semibold text-srt-navy shrink-0 mt-0.5">
                                @authorName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()?.FirstOrDefault()
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-medium text-gray-900">@authorName</span>
                                    @if (log.IsConfidential)
                                    {
                                        <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-red-100 text-red-700">
                                            🔒 ลับ
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-600">
                                            บันทึกทั่วไป
                                        </span>
                                    }
                                    <span class="text-xs text-gray-400 ml-auto">
                                        @log.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")
                                    </span>
                                </div>
                                <p class="text-sm text-gray-700 bg-gray-50 rounded-xl px-3 py-2 whitespace-pre-wrap">
                                    @log.Content
                                </p>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ④ Decryption Audit Trail -->
        @if (r.DecryptionLogs.Any())
        {
            <div class="bg-white rounded-xl border border-amber-200 shadow-sm p-5">
                <h2 class="text-sm font-semibold text-gray-900 mb-4 flex items-center gap-2">
                    <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    ประวัติการขอดูข้อมูลผู้แจ้ง (Audit)
                </h2>
                <div class="space-y-2">
                    @foreach (var dlog in r.DecryptionLogs.OrderByDescending(l => l.RequestedAt))
                    {
                        var requesterName = Model.StaffNames.GetValueOrDefault(dlog.RequestedById, $"Staff #{dlog.RequestedById}");
                        <div class="flex items-start gap-3 text-xs bg-amber-50 border border-amber-100 rounded-lg p-3">
                            <svg class="w-4 h-4 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
                            </svg>
                            <div class="flex-1 min-w-0">
                                <span class="font-semibold text-gray-900">@requesterName</span>
                                <span class="text-gray-500"> ขอดูข้อมูล — เหตุผล: </span>
                                <span class="text-gray-700 italic">@dlog.Reason</span>
                            </div>
                            <div class="text-right text-gray-400 shrink-0">
                                <p>@dlog.RequestedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</p>
                                @if (!string.IsNullOrEmpty(dlog.IpAddress))
                                {
                                    <p class="font-mono">IP: @dlog.IpAddress</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

    </div>

    <!-- ── Right: Action Panel ── -->
    <div class="space-y-4">

        <!-- Claim -->
        @if (r.AssignedToId == null && r.Status == "Pending")
        {
            <div class="bg-amber-50 border border-amber-300 rounded-xl p-4">
                <p class="text-sm text-amber-800 font-medium mb-3">ยังไม่มีผู้รับผิดชอบ</p>
                <form method="post" asp-page-handler="Claim" asp-route-id="@r.Id">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full bg-amber-600 text-white text-sm font-medium py-2.5 rounded-xl
                                   hover:bg-amber-700 transition">
                        รับเรื่องสืบสวน
                    </button>
                </form>
            </div>
        }

        <!-- Update Status -->
        @if (!isClosed && Model.AllowedNextStatuses.Length > 0)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">อัปเดตสถานะ</h3>
                <form method="post" asp-page-handler="UpdateStatus" asp-route-id="@r.Id">
                    @Html.AntiForgeryToken()
                    <select name="NewStatus"
                            class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm mb-3
                                   focus:outline-none focus:border-srt-navy">
                        <option value="">— เลือกสถานะใหม่ —</option>
                        @foreach (var st in Model.AllowedNextStatuses)
                        {
                            <option value="@st">@CaseDetailModel.StatusLabel(st)</option>
                        }
                    </select>
                    <button type="submit"
                            class="w-full border border-srt-navy text-srt-navy text-sm font-medium py-2 rounded-xl
                                   hover:bg-srt-navy hover:text-white transition">
                        บันทึกสถานะ
                    </button>
                </form>
            </div>
        }

        <!-- Add Investigation Log -->
        @if (!isClosed)
        {
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-gray-900 mb-3">เพิ่มบันทึกการสืบสวน</h3>
                <form method="post" asp-page-handler="AddLog" asp-route-id="@r.Id">
                    @Html.AntiForgeryToken()
                    <textarea name="InvLogContent" rows="4"
                              placeholder="บันทึกผลการสืบสวน หลักฐาน หรือขั้นตอนดำเนินการ..."
                              class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm mb-3
                                     focus:outline-none focus:border-srt-navy focus:ring-2 focus:ring-srt-navy/10
                                     resize-none"></textarea>
                    <label class="flex items-center gap-2 text-xs text-gray-600 mb-3 cursor-pointer">
                        <input type="checkbox" name="InvLogIsConfidential" value="true" checked
                               class="w-4 h-4 rounded border-gray-300 accent-red-600" />
                        <span class="text-red-600 font-medium">🔒 บันทึกลับ</span>
                        (เฉพาะผู้สืบสวนดูได้)
                    </label>
                    <button type="submit"
                            class="w-full border border-gray-300 text-gray-700 text-sm font-medium py-2 rounded-xl
                                   hover:bg-gray-50 transition">
                        บันทึก
                    </button>
                </form>
            </div>
        }

        <!-- Close Case -->
        @if (r.Status == "UnderReview")
        {
            <div class="bg-white rounded-xl border border-red-200 shadow-sm p-4">
                <h3 class="text-sm font-semibold text-red-700 mb-3">ปิดเรื่อง / สรุปผล</h3>
                <form method="post" asp-page-handler="Close" asp-route-id="@r.Id">
                    @Html.AntiForgeryToken()
                    <textarea name="CloseResolution" rows="3" required
                              placeholder="สรุปผลการสืบสวนและการดำเนินการ (จำเป็น)..."
                              class="w-full border border-red-200 rounded-xl px-3 py-2 text-sm mb-3
                                     focus:outline-none focus:border-red-400 focus:ring-2 focus:ring-red-100
                                     resize-none"></textarea>
                    <button type="submit"
                            onclick="return confirm('ยืนยันการปิดเรื่องทุจริตนี้?')"
                            class="w-full bg-red-600 text-white text-sm font-medium py-2 rounded-xl
                                   hover:bg-red-700 transition">
                        ปิดเรื่อง
                    </button>
                </form>
            </div>
        }

        <!-- Closed state -->
        @if (isClosed)
        {
            <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-center">
                <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-sm text-gray-500">เรื่องนี้ปิดแล้ว</p>
                @if (r.ClosedAt.HasValue)
                {
                    <p class="text-xs text-gray-400 mt-1">
                        @r.ClosedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </p>
                }
                @if (r.Status == "Closed")
                {
                    <form method="post" asp-page-handler="Reopen" asp-route-id="@r.Id" class="mt-3">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                onclick="return confirm('เปิดเรื่องนี้ใหม่อีกครั้ง?')"
                                class="inline-flex items-center gap-1.5 text-xs text-amber-700 border border-amber-300
                                       bg-amber-50 px-3 py-1.5 rounded-lg hover:bg-amber-100 transition">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                            เปิดเรื่องใหม่
                        </button>
                    </form>
                }
            </div>
        }

        <!-- Summary stats -->
        <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-xs text-gray-500 space-y-1.5">
            <div class="flex justify-between">
                <span>บันทึกสืบสวน</span>
                <span class="font-medium text-gray-700">@r.InvestigationLogs.Count รายการ</span>
            </div>
            <div class="flex justify-between">
                <span>ขอดูข้อมูลผู้แจ้ง</span>
                <span class="font-medium @(r.DecryptionLogs.Any() ? "text-amber-600" : "text-gray-700")">
                    @r.DecryptionLogs.Count ครั้ง
                </span>
            </div>
        </div>

    </div>
</div>
